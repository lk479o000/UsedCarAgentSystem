.guest-tip {
  position: relative;
  overflow: hidden;
  padding: 28rpx;
  border-radius: 28rpx;
  margin-bottom: 24rpx;
  /* Neo glass: blur 8–12px + alpha 0.75 */
  background: rgba(6, 16, 34, 0.38) !important;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  /* shadow: rgba(0,0,0,0.25), y=4px, blur=12px */
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.25);
  animation: guestFadeIn 0.3s ease-out both;
}

@keyframes guestFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.guest-bg {
  position: absolute;
  inset: 0;
  opacity: 1;
  pointer-events: none;
  background:
    radial-gradient(520rpx 220rpx at 85% 50%, rgba(0, 191, 255, 0.18) 0%, rgba(0, 191, 255, 0) 62%),
    radial-gradient(520rpx 240rpx at 10% 20%, rgba(139, 92, 246, 0.16) 0%, rgba(139, 92, 246, 0) 60%),
    linear-gradient(135deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.02) 100%);
}

.guest-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.guest-icon {
  /* 32px */
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.10);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  color: rgba(255, 255, 255, 0.75);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  flex-shrink: 0;
  /* button shadow: rgba(0,0,0,0.15), y=2px, blur=8px */
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.guest-icon-user {
  width: 34rpx;
  height: 34rpx;
  position: relative;
}

.guest-icon-user::before {
  content: '';
  position: absolute;
  top: 1rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.72);
  box-sizing: border-box;
}

.guest-icon-user::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 18rpx;
  border-radius: 16rpx 16rpx 10rpx 10rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.72);
  border-top: 0;
  box-sizing: border-box;
}

.guest-tip:active .guest-icon {
  border-color: var(--neo-neon-blue, #00BFFF);
  box-shadow:
    0 4rpx 16rpx rgba(0, 0, 0, 0.15),
    0 0 12rpx rgba(0, 191, 255, 0.45),
    0 0 24rpx rgba(0, 191, 255, 0.25);
}

.guest-tip:active .guest-icon-user::before,
.guest-tip:active .guest-icon-user::after {
  border-color: rgba(0, 191, 255, 0.95);
}

.guest-text {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.guest-title {
  color: #FFFFFF !important;
  /* 16px */
  font-size: 32rpx !important;
  font-weight: 700 !important;
  line-height: 40rpx !important;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif !important;
}

.guest-sub {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.7) !important;
  /* 12px */
  font-size: 24rpx !important;
  font-weight: 500 !important;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif !important;
}

.guest-btn {
  flex-shrink: 0;
  margin-left: 16rpx !important;
  width: 120rpx !important;
  height: 68rpx !important;
  line-height: 68rpx !important;
  /* 8px */
  border-radius: 16rpx !important;
  /* 14px */
  font-size: 28rpx !important;
  font-weight: 700 !important;
  padding: 0 !important;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif !important;
  background: linear-gradient(90deg, #00BFFF 0%, #0080FF 100%) !important;
  color: #fff !important;
  border: none !important;
  /* rgba(0,0,0,0.25), y=2px, blur=6px */
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.25) !important;
  transition: transform 0.15s ease, box-shadow 0.2s ease;
}

.guest-btn::after {
  border: none !important;
}

.guest-btn:active {
  transform: scale(1.05);
  box-shadow:
    0 4rpx 12rpx rgba(0, 0, 0, 0.25),
    0 0 0 2rpx rgba(0, 191, 255, 0.95),
    0 0 16rpx rgba(0, 191, 255, 0.45);
}