page {
  background: #F1F5F9;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.container {
  padding: 24rpx;
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* 统计卡片 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #E2E8F0;
  transition: all 0.3s ease;
}

.stat-card:active {
  transform: scale(0.98);
}

.stat-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: 16rpx;
}

.stat-icon.blue {
  background: linear-gradient(135deg, rgba(14, 165, 233, 0.15) 0%, rgba(56, 189, 248, 0.15) 100%);
  color: #0EA5E9;
}

.stat-icon.green {
  background: linear-gradient(135deg, rgba(20, 184, 166, 0.15) 0%, rgba(34, 211, 238, 0.15) 100%);
  color: #14B8A6;
}

.stat-icon.orange {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.15) 0%, rgba(251, 191, 36, 0.15) 100%);
  color: #F59E0B;
}

.stat-icon.red {
  background: linear-gradient(135deg, rgba(239, 68, 68, 0.15) 0%, rgba(248, 113, 113, 0.15) 100%);
  color: #EF4444;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #0F172A;
  letter-spacing: -0.02em;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 8rpx;
  font-weight: 500;
}

/* 快捷入口 */
.quick-actions {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #E2E8F0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0F172A;
  margin-bottom: 24rpx;
  letter-spacing: -0.02em;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 0;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.action-item:active {
  background: rgba(14, 165, 233, 0.08);
  transform: scale(0.95);
}

.action-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.action-icon.blue {
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  color: #fff;
}

.action-icon.green {
  background: linear-gradient(135deg, #14B8A6 0%, #22D3EE 100%);
  color: #fff;
}

.action-icon.orange {
  background: linear-gradient(135deg, #F59E0B 0%, #FBBF24 100%);
  color: #fff;
}

.action-icon.red {
  background: linear-gradient(135deg, #EF4444 0%, #F87171 100%);
  color: #fff;
}

.action-label {
  font-size: 24rpx;
  color: #475569;
  font-weight: 500;
}

/* 最近线索 */
.recent-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #E2E8F0;
}

.lead-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E2E8F0;
  transition: all 0.3s ease;
}

.lead-item:last-child {
  border-bottom: none;
}

.lead-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.lead-info {
  flex: 1;
  min-width: 0;
}

.lead-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #0F172A;
  margin-bottom: 8rpx;
}

.lead-car {
  font-size: 24rpx;
  color: #94A3B8;
}

.lead-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.lead-status.tag-primary {
  background: rgba(14, 165, 233, 0.1);
  color: #0369A1;
}

.lead-status.tag-success {
  background: rgba(20, 184, 166, 0.1);
  color: #14B8A6;
}

.lead-status.tag-warning {
  background: rgba(245, 158, 11, 0.1);
  color: #F59E0B;
}

.lead-status.tag-danger {
  background: rgba(239, 68, 68, 0.1);
  color: #EF4444;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #94A3B8;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
  opacity: 0.5;
}
