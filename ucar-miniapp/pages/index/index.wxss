page {
  background: transparent;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.page {
  padding: 24rpx;
  padding-bottom: 160rpx;
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* 统计卡片 */
.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  padding: 22rpx 22rpx;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  min-height: 156rpx;
}

.stat-card--wide {
  grid-column: 1 / -1;
  min-height: 140rpx;
}

.stat-card:active {
  transform: scale(0.96);
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.15);
}

.stat-bg {
  position: absolute;
  inset: 0;
  opacity: 0.9;
  pointer-events: none;
}

.stat-card--blue .stat-bg {
  background:
    radial-gradient(520rpx 220rpx at 12% 10%, rgba(56, 189, 248, 0.35) 0%, rgba(56, 189, 248, 0) 60%),
    linear-gradient(135deg, rgba(14, 165, 233, 0.10) 0%, rgba(56, 189, 248, 0.06) 100%);
}

.stat-card--green .stat-bg {
  background:
    radial-gradient(520rpx 220rpx at 12% 10%, rgba(34, 211, 238, 0.30) 0%, rgba(34, 211, 238, 0) 60%),
    linear-gradient(135deg, rgba(20, 184, 166, 0.10) 0%, rgba(34, 211, 238, 0.06) 100%);
}

.stat-card--red .stat-bg {
  background:
    radial-gradient(520rpx 220rpx at 12% 10%, rgba(248, 113, 113, 0.30) 0%, rgba(248, 113, 113, 0) 60%),
    linear-gradient(135deg, rgba(239, 68, 68, 0.10) 0%, rgba(248, 113, 113, 0.06) 100%);
}

.stat-card--orange .stat-bg {
  background:
    radial-gradient(520rpx 220rpx at 12% 10%, rgba(251, 191, 36, 0.30) 0%, rgba(251, 191, 36, 0) 60%),
    linear-gradient(135deg, rgba(245, 158, 11, 0.10) 0%, rgba(251, 191, 36, 0.06) 100%);
}

.stat-card--teal .stat-bg {
  background:
    radial-gradient(520rpx 220rpx at 12% 10%, rgba(125, 211, 252, 0.30) 0%, rgba(125, 211, 252, 0) 60%),
    linear-gradient(135deg, rgba(14, 165, 233, 0.07) 0%, rgba(20, 184, 166, 0.08) 100%);
}

.stat-main {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.stat-kpi {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.stat-side {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.stat-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  box-shadow: 0 10rpx 22rpx rgba(2, 6, 23, 0.10);
}

.stat-icon .i-lucide-list,
.stat-icon .i-lucide-check-circle,
.stat-icon .i-lucide-x-circle,
.stat-icon .i-lucide-wallet {
  font-size: 32rpx;
}

.stat-icon.blue {
  background: linear-gradient(135deg, rgba(14, 165, 233, 0.15) 0%, rgba(56, 189, 248, 0.15) 100%);
  color: #0EA5E9;
}

.stat-icon.green {
  background: linear-gradient(135deg, rgba(20, 184, 166, 0.15) 0%, rgba(34, 211, 238, 0.15) 100%);
  color: #14B8A6;
}

.stat-icon.orange {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.15) 0%, rgba(251, 191, 36, 0.15) 100%);
  color: #F59E0B;
}

.stat-icon.red {
  background: linear-gradient(135deg, rgba(239, 68, 68, 0.15) 0%, rgba(248, 113, 113, 0.15) 100%);
  color: #EF4444;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #0F172A;
  letter-spacing: -0.02em;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: #94A3B8;
  font-weight: 500;
}

.stat-chevron {
  font-size: 28rpx;
  color: rgba(148, 163, 184, 0.9);
}

/* 快捷入口 */
.quick-actions {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0F172A;
  margin-bottom: 24rpx;
  letter-spacing: -0.02em;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 0;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.action-item:active {
  background: rgba(14, 165, 233, 0.15);
  transform: scale(0.92);
}

.action-item:active .action-icon {
  opacity: 0.8;
  transform: scale(0.95);
}

.action-item:active .action-label {
  color: #0EA5E9;
}

.action-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.action-icon .i-lucide-list,
.action-icon .i-lucide-wallet,
.action-icon .i-lucide-user,
.action-icon .i-lucide-refresh-cw {
  font-size: 40rpx;
  color: #fff;
}

.action-icon.blue {
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  color: #fff;
}

.action-icon.green {
  background: linear-gradient(135deg, #14B8A6 0%, #22D3EE 100%);
  color: #fff;
}

.action-icon.orange {
  background: linear-gradient(135deg, #F59E0B 0%, #FBBF24 100%);
  color: #fff;
}

.action-icon.red {
  background: linear-gradient(135deg, #EF4444 0%, #F87171 100%);
  color: #fff;
}

.action-label {
  font-size: 24rpx;
  color: #475569;
  font-weight: 500;
}

/* 最近线索 */
.recent-section {
  padding: 32rpx;
}

.lead-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.5);
  transition: all 0.3s ease;
}

.lead-item:last-child {
  border-bottom: none;
}

.lead-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.lead-info {
  flex: 1;
  min-width: 0;
}

.lead-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #0F172A;
  margin-bottom: 8rpx;
}

.lead-car {
  font-size: 24rpx;
  color: #94A3B8;
}

.lead-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.lead-status.tag-primary {
  background: rgba(14, 165, 233, 0.1);
  color: #0369A1;
}

.lead-status.tag-success {
  background: rgba(20, 184, 166, 0.1);
  color: #14B8A6;
}

.lead-status.tag-warning {
  background: rgba(245, 158, 11, 0.1);
  color: #F59E0B;
}

.lead-status.tag-danger {
  background: rgba(239, 68, 68, 0.1);
  color: #EF4444;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #94A3B8;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
  opacity: 0.5;
}
