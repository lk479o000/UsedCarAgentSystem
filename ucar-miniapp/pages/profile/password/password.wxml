<view class="pwd-page">
  <view class="bg-gradient"></view>

  <view class="content">
    <view class="card card-glass">
      <view class="title">修改密码</view>

      <view class="field">
        <view class="label">原密码</view>
        <input class="input" password placeholder="请输入原密码" value="{{oldPassword}}" bindinput="onOldPasswordInput" />
      </view>

      <view class="field">
        <view class="label">新密码</view>
        <input class="input" password placeholder="至少8位，包含字母和数字" value="{{newPassword}}" bindinput="onNewPasswordInput" />
      </view>

      <view class="field">
        <view class="label">确认密码</view>
        <input class="input" password placeholder="请再次输入新密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
      </view>

      <button class="submit neon-btn" loading="{{loading}}" bindtap="onSubmit">确认修改</button>
    </view>
  </view>
</view>

