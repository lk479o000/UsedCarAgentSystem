<view class="aura-page">
  <view class="aura-bg"></view>

  <view class="aura-content">
    <view class="header card-glass">
      <view class="header-icon">
        <view class="icon-box i-lucide-lock"></view>
      </view>
      <view class="header-title">修改密码</view>
      <view class="header-subtitle">请定期更换密码以保障账户安全</view>
    </view>

    <view class="card-glass form-card">
      <view class="form-item">
        <view class="form-label">原密码</view>
        <view class="form-control">
          <view class="prefix-icon i-lucide-lock-keyhole"></view>
          <input
            class="form-input"
            type="{{oldPasswordVisible ? 'text' : 'password'}}"
            placeholder="请输入原密码"
            value="{{oldPassword}}"
            bindinput="onOldPasswordInput"
            password="{{!oldPasswordVisible}}"
          />
          <view
            class="suffix-icon {{oldPasswordVisible ? 'i-lucide-eye-off' : 'i-lucide-eye'}}"
            bindtap="toggleOldPasswordVisible"
          ></view>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">新密码</view>
        <view class="form-control">
          <view class="prefix-icon i-lucide-lock-keyhole"></view>
          <input
            class="form-input"
            type="{{newPasswordVisible ? 'text' : 'password'}}"
            placeholder="至少8位，包含字母和数字"
            value="{{newPassword}}"
            bindinput="onNewPasswordInput"
            password="{{!newPasswordVisible}}"
          />
          <view
            class="suffix-icon {{newPasswordVisible ? 'i-lucide-eye-off' : 'i-lucide-eye'}}"
            bindtap="toggleNewPasswordVisible"
          ></view>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">确认密码</view>
        <view class="form-control">
          <view class="prefix-icon i-lucide-lock-keyhole"></view>
          <input
            class="form-input"
            type="{{confirmPasswordVisible ? 'text' : 'password'}}"
            placeholder="请再次输入新密码"
            value="{{confirmPassword}}"
            bindinput="onConfirmPasswordInput"
            password="{{!confirmPasswordVisible}}"
          />
          <view
            class="suffix-icon {{confirmPasswordVisible ? 'i-lucide-eye-off' : 'i-lucide-eye'}}"
            bindtap="toggleConfirmPasswordVisible"
          ></view>
        </view>
      </view>

      <button class="submit-btn btn-primary" loading="{{loading}}" bindtap="onSubmit">确认修改</button>
    </view>
  </view>
</view>
