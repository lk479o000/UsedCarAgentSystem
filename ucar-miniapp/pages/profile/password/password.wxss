page {
  background: transparent;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 26rpx 32rpx;
  border-radius: 32rpx;
  margin-bottom: 18rpx;
}

.header-icon {
  margin-bottom: 20rpx;
}

.icon-box {
  width: 112rpx;
  height: 112rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #0EA5E9, #38BDF8);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.35);
}

.header-title {
  font-size: 34rpx;
  font-weight: 900;
  color: rgba(15, 23, 42, 0.92);
  text-align: center;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(71, 85, 105, 0.75);
  margin-top: 8rpx;
  text-align: center;
}

.form-card {
  padding: 30rpx 26rpx;
  border-radius: 32rpx;
}

.form-item {
  margin-bottom: 22rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(15, 23, 42, 0.78);
  margin-bottom: 12rpx;
}

.form-control {
  height: 88rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.75);
  border: 2rpx solid rgba(148, 163, 184, 0.35);
  font-size: 28rpx;
  color: #0F172A;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.prefix-icon {
  font-size: 36rpx;
  color: rgba(148, 163, 184, 0.85);
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.form-input {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  color: #0F172A;
  min-width: 0;
}

.suffix-icon {
  font-size: 36rpx;
  color: rgba(148, 163, 184, 0.85);
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn {
  margin-top: 26rpx;
  width: 100%;
  height: 96rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: normal;
}

.submit-btn::after {
  border: none;
}
