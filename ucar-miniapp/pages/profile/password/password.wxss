page {
  background: #0B1220;
}

.pwd-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.bg-gradient {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  height: 520rpx;
  background: radial-gradient(900rpx 520rpx at 20% 15%, rgba(34, 211, 238, 0.45), rgba(34, 211, 238, 0) 60%),
    radial-gradient(800rpx 520rpx at 80% 10%, rgba(139, 92, 246, 0.42), rgba(139, 92, 246, 0) 62%),
    linear-gradient(135deg, #0B1220 0%, #0B2A4A 40%, #1B1A55 100%);
}

.content {
  position: relative;
  padding: 28rpx 22rpx;
  animation: fadeIn 0.4s ease-out;
}

.card {
  padding: 30rpx 26rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.10);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  box-shadow: 0 18rpx 60rpx rgba(0, 0, 0, 0.28);
}

.title {
  font-size: 34rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.92);
  text-align: center;
  margin-bottom: 26rpx;
}

.field {
  margin-top: 16rpx;
}

.label {
  font-size: 22rpx;
  font-weight: 800;
  color: rgba(226, 232, 240, 0.55);
  margin-bottom: 10rpx;
}

.input {
  height: 90rpx;
  padding: 0 20rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.10);
  border: 1rpx solid rgba(34, 211, 238, 0.20);
  color: rgba(255, 255, 255, 0.92);
  font-size: 28rpx;
  box-sizing: border-box;
}

.neon-btn {
  height: 92rpx;
  line-height: 92rpx;
  padding: 0 26rpx;
  border-radius: 9999rpx;
  background: rgba(34, 211, 238, 0.16);
  border: 1rpx solid rgba(34, 211, 238, 0.45);
  color: rgba(255, 255, 255, 0.92);
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 0 0 20rpx rgba(34, 211, 238, 0.20);
  margin-top: 26rpx;
  width: 100%;
}

.neon-btn:active {
  transform: scale(0.98);
  box-shadow: 0 0 28rpx rgba(34, 211, 238, 0.30);
}

.neon-btn::after {
  border: none;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

