<view class="page p-4">
  <view class="profile-header card-glass">
    <view class="avatar">
      <open-data type="userAvatarUrl"></open-data>
    </view>
    <view class="user-info">
      <view class="nickname">
        <open-data type="userNickName"></open-data>
      </view>
      <view class="phone" wx:if="{{userInfo.phone}}">{{userInfo.phone}}</view>
    </view>
  </view>

  <view class="menu-list card-glass">
    <view class="menu-item">
      <view class="menu-left">
        <view class="menu-icon icon-user i-lucide-user"></view>
        <text class="menu-label">姓名</text>
      </view>
      <text class="menu-value">{{userInfo.username || '-'}}</text>
    </view>
    <view class="menu-item">
      <view class="menu-left">
        <view class="menu-icon icon-role i-lucide-shield"></view>
        <text class="menu-label">角色</text>
      </view>
      <text class="menu-value">{{userInfo.role === 1 ? '经纪人' : '管理员'}}</text>
    </view>
    <view class="menu-item">
      <view class="menu-left">
        <view class="menu-icon icon-status i-lucide-activity"></view>
        <text class="menu-label">状态</text>
      </view>
      <text class="menu-value {{userInfo.status === 1 ? 'enabled' : 'disabled'}}">
        {{userInfo.status === 1 ? '正常' : '禁用'}}
      </text>
    </view>
  </view>

  <button class="logout-btn btn-danger i-lucide-log-out" bindtap="logout">退出登录</button>
</view>
