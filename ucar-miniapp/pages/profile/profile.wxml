<view class="aura-page with-tabbar">
  <view class="aura-bg"></view>

  <view class="aura-content">
    <guest-tip wx:if="{{isGuest}}" tip-text="登录后可查看账号信息与进行账号操作" />

    <view wx:if="{{!isGuest}}" class="header card-glass">
      <view class="avatar-zone">
        <view class="avatar-ring animate-glow">
          <image wx:if="{{form.avatarUrl}}" class="avatar-img" mode="aspectFill" src="{{form.avatarUrl}}"></image>
          <open-data wx:else class="avatar-open" type="userAvatarUrl"></open-data>
        </view>
        <view class="avatar-actions">
          <button class="btn-ghost" bindtap="syncWechatProfile" loading="{{syncingWxProfile}}">同步微信头像/昵称</button>
        </view>
      </view>

      <view class="center">
        <input class="nick-input" placeholder="请输入昵称" value="{{form.nickname}}" bindinput="onNicknameInput" />
        <view class="phone-row">
          <text class="phone-text">{{form.phone || '未同步手机号'}}</text>
        </view>
        <button
          class="btn-primary"
          open-type="getPhoneNumber"
          bindgetphonenumber="onGetPhoneNumber"
          loading="{{syncingPhone}}"
        >
          同步微信手机号
        </button>
      </view>
    </view>

    <view wx:if="{{!isGuest}}" class="card-glass section">
      <view class="section-title">账号信息</view>

      <view class="field">
        <view class="label">头像 URL</view>
        <input class="input" placeholder="可粘贴头像图片 URL" value="{{form.avatarUrl}}" bindinput="onAvatarUrlInput" />
      </view>

      <view class="field">
        <view class="label">姓名</view>
        <input class="input" placeholder="请输入姓名" value="{{form.username}}" bindinput="onUsernameInput" />
      </view>

      <view class="field readonly">
        <view class="label">角色</view>
        <view class="value">{{roleText}}</view>
      </view>

      <view class="field readonly">
        <view class="label">状态</view>
        <view class="value {{statusClass}}">{{statusText}}</view>
      </view>

      <button class="save-btn btn-primary" bindtap="saveProfile" loading="{{saving}}">保存资料</button>
    </view>

    <view wx:if="{{!isGuest}}" class="card-glass section">
      <view class="section-title">操作</view>

      <view class="op-item" bindtap="goChangePassword">
        <view class="op-left">
          <view class="op-icon i-lucide-lock"></view>
          <text class="op-text">修改密码</text>
        </view>
        <view class="op-arrow i-lucide-chevron-right"></view>
      </view>

      <view class="op-item" bindtap="goToAgreement">
        <view class="op-left">
          <view class="op-icon i-lucide-file-text"></view>
          <text class="op-text">用户协议</text>
        </view>
        <view class="op-arrow i-lucide-chevron-right"></view>
      </view>

      <view class="op-item" bindtap="goToPrivacy">
        <view class="op-left">
          <view class="op-icon i-lucide-shield"></view>
          <text class="op-text">隐私政策</text>
        </view>
        <view class="op-arrow i-lucide-chevron-right"></view>
      </view>
    </view>
  </view>

  <view wx:if="{{!isGuest}}" class="logout-wrap">
    <view class="logout-base card-glass">
      <button class="logout-btn" bindtap="logout">退出登录</button>
    </view>
  </view>
</view>
