page { background: transparent; }

.aura-page.with-tabbar {
  padding-bottom: calc(var(--tabbar-height) + env(safe-area-inset-bottom) + 16rpx) !important;
}

.header {
  padding: 30rpx 26rpx;
  border-radius: 32rpx;
}

.avatar-zone {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-ring {
  width: 168rpx;
  height: 168rpx;
  border-radius: 9999rpx;
  padding: 8rpx;
  background: linear-gradient(135deg, rgba(34, 211, 238, 0.95), rgba(139, 92, 246, 0.9));
  box-shadow: 0 0 0 2rpx rgba(34, 211, 238, 0.35), 0 0 34rpx rgba(34, 211, 238, 0.35);
  box-sizing: border-box;
}

.avatar-img,
.avatar-open {
  width: 100%;
  height: 100%;
  border-radius: 9999rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.12);
}

.avatar-actions {
  margin-top: 16rpx;
}

.center {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.nick-input {
  width: 100%;
  text-align: center;
  font-size: 40rpx;
  font-weight: 900;
  color: rgba(15, 23, 42, 0.92);
  padding: 10rpx 10rpx;
}

.phone-row {
  display: flex;
  align-items: center;
  justify-content: center;
}

.phone-text {
  font-size: 26rpx;
  color: rgba(71, 85, 105, 0.85);
}

.section {
  margin-top: 18rpx;
  padding: 26rpx 24rpx;
  border-radius: 32rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 900;
  color: rgba(15, 23, 42, 0.55);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-bottom: 18rpx;
}

.field {
  margin-top: 14rpx;
}

.label {
  font-size: 22rpx;
  font-weight: 800;
  color: rgba(15, 23, 42, 0.55);
  margin-bottom: 10rpx;
}

.input {
  height: 90rpx;
  padding: 0 20rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.75);
  border: 2rpx solid rgba(148, 163, 184, 0.35);
  color: rgba(15, 23, 42, 0.92);
  font-size: 28rpx;
  box-sizing: border-box;
}

.readonly .value {
  height: 90rpx;
  border-radius: 26rpx;
  background: rgba(241, 245, 249, 0.8);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  color: rgba(15, 23, 42, 0.86);
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.value.ok { color: rgba(16, 185, 129, 0.95); }
.value.bad { color: rgba(248, 113, 113, 0.95); }

.btn-primary::after,
.btn-ghost::after {
  border: none;
}

.save-btn {
  margin-top: 20rpx;
  width: 100%;
}

.op-item {
  height: 96rpx;
  border-radius: 26rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.75);
  border: 1rpx solid rgba(226, 232, 240, 0.85);
  margin-top: 14rpx;
}

.op-item:active {
  border-color: rgba(34, 211, 238, 0.35);
  box-shadow: 0 0 20rpx rgba(34, 211, 238, 0.20);
}

.op-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.op-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(14, 165, 233, 0.12);
  color: rgba(14, 165, 233, 0.95);
  font-size: 30rpx;
}

.op-text {
  font-size: 30rpx;
  font-weight: 800;
  color: rgba(15, 23, 42, 0.9);
}

.op-arrow {
  color: rgba(71, 85, 105, 0.55);
}

.logout-wrap {
  margin-top: 18rpx;
  padding: 16rpx 20rpx;
}

.logout-base {
  border-radius: 36rpx;
  padding: 14rpx;
}

.logout-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #EF4444, #F87171);
  border: 1rpx solid rgba(34, 211, 238, 0.55);
  color: #fff;
  font-size: 32rpx;
  font-weight: 900;
  box-shadow: 0 0 26rpx rgba(34, 211, 238, 0.22), 0 10rpx 30rpx rgba(239, 68, 68, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-btn:active {
  transform: scale(0.98);
}

.logout-btn::after {
  border: none;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}
