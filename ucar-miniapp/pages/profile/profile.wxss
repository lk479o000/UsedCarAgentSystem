page {
  background: #F1F5F9;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.container {
  padding: 30rpx;
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* 头部信息 */
.profile-header {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.3);
  position: relative;
  overflow: hidden;
}

.profile-header::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 30rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  position: relative;
  z-index: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 10rpx;
  letter-spacing: -0.02em;
}

.phone {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

/* 菜单列表 */
.menu-list {
  background: #FFFFFF;
  border-radius: 32rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #E2E8F0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #E2E8F0;
  transition: all 0.3s ease;
}

.menu-item:active {
  background: rgba(14, 165, 233, 0.05);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.icon-user {
  background: linear-gradient(135deg, rgba(14, 165, 233, 0.15) 0%, rgba(56, 189, 248, 0.15) 100%);
}

.icon-role {
  background: linear-gradient(135deg, rgba(20, 184, 166, 0.15) 0%, rgba(34, 211, 238, 0.15) 100%);
}

.icon-status {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.15) 0%, rgba(251, 191, 36, 0.15) 100%);
}

.menu-label {
  font-size: 30rpx;
  color: #0F172A;
  font-weight: 500;
}

.menu-value {
  font-size: 28rpx;
  color: #475569;
  font-weight: 500;
}

.menu-value.enabled {
  color: #14B8A6;
}

.menu-value.disabled {
  color: #EF4444;
}

/* 退出按钮 */
.logout-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 32rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 20rpx;
  background: linear-gradient(135deg, #EF4444 0%, #F87171 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(239, 68, 68, 0.3);
  transition: all 0.3s ease;
}

.logout-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(239, 68, 68, 0.2);
}

.logout-btn::after {
  border: none;
}
