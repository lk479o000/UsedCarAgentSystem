page {
  background: #F1F5F9;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.page {
  padding: 24rpx;
  padding-bottom: 140rpx;
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* 筛选栏 - 横向滚动 */
.filter-bar {
  display: flex;
  padding: 12rpx;
  margin-bottom: 16rpx;
  white-space: nowrap;
}

.filter-item {
  display: inline-block;
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  color: #94A3B8;
  border-radius: 24rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.filter-item.active {
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(14, 165, 233, 0.3);
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.search-icon {
  font-size: 32rpx;
  color: #94A3B8;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #0F172A;
  height: 48rpx;
}

/* 线索卡片 */
.lead-list {
  margin-bottom: 24rpx;
}

.lead-card {
  padding: 32rpx;
  margin-bottom: 24rpx;
  transition: all 0.3s ease;
}

.lead-card:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.15);
}

.lead-header {
  margin-bottom: 20rpx;
}

.customer-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.customer-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #0F172A;
  letter-spacing: -0.02em;
}

.customer-phone {
  font-size: 26rpx;
  color: #94A3B8;
  font-weight: 500;
}

/* 状态标签 */
.lead-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.lead-status.tag-primary {
  background: rgba(14, 165, 233, 0.1);
  color: #0369A1;
}

.lead-status.tag-success {
  background: rgba(20, 184, 166, 0.1);
  color: #14B8A6;
}

.lead-status.tag-warning {
  background: rgba(245, 158, 11, 0.1);
  color: #F59E0B;
}

.lead-status.tag-danger {
  background: rgba(239, 68, 68, 0.1);
  color: #EF4444;
}

/* 车辆信息 */
.car-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(226, 232, 240, 0.5);
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.5);
  margin-bottom: 20rpx;
}

.car-label {
  font-size: 24rpx;
  color: #94A3B8;
  background: rgba(241, 245, 249, 0.8);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.car-value {
  font-size: 28rpx;
  color: #0F172A;
  font-weight: 500;
}

/* 底部信息 */
.lead-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.agent-name {
  font-size: 24rpx;
  color: #0EA5E9;
  font-weight: 500;
}

.create-time {
  font-size: 24rpx;
  color: #94A3B8;
  font-weight: 500;
}

/* 悬浮新增按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.4);
  z-index: 100;
  transition: all 0.3s ease;
}

.fab-btn:active {
  transform: scale(0.9);
  box-shadow: 0 4rpx 12rpx rgba(14, 165, 233, 0.5);
}

.fab-icon {
  font-size: 48rpx;
  color: #fff;
}

/* 加载和空状态 */
.loading, .no-more {
  text-align: center;
  padding: 30rpx;
  color: #94A3B8;
  font-size: 26rpx;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #94A3B8;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
  opacity: 0.5;
}
