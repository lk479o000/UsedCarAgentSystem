page {
  background: transparent;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.page {
  padding: 24rpx;
  padding-bottom: 140rpx;
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* 筛选栏 - 横向滚动 */
/* filter-bar/filter-item 已沉淀到 app.wxss */

/* 筛选栏 - 折叠面板 */
.filter-panel {
  padding: 18rpx 18rpx;
  margin-bottom: 24rpx;
}

.filter-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.filter-head-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.filter-head-icon {
  font-size: 34rpx !important;
  width: 50rpx !important;
  height: 34rpx !important;
  flex-shrink: 0;
  color: var(--primary);
}

.filter-head-title {
  font-size: 26rpx;
  font-weight: 800;
  color: rgba(15, 23, 42, 0.85);
}

.filter-head-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: rgba(71, 85, 105, 0.9);
}

.filter-current {
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(71, 85, 105, 0.88);
}

.filter-head-arrow {
  font-size: 30rpx;
  transition: transform 0.15s ease;
}

.filter-head-arrow.up {
  transform: rotate(180deg);
}

.filter-body {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.filter-chip {
  height: 64rpx;
  padding: 0 22rpx;
  border-radius: 9999rpx;
  background: rgba(15, 23, 42, 0.05);
  color: rgba(71, 85, 105, 0.92);
  font-size: 24rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.filter-chip.active {
  background: rgba(14, 165, 233, 0.14);
  color: #0369A1;
  box-shadow: 0 4rpx 16rpx rgba(14, 165, 233, 0.18);
}

/* 筛选区域 */
.search-section {
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.search-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.search-label {
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: rgba(241, 245, 249, 0.8);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  gap: 12rpx;
}

.search-icon-small {
  font-size: 32rpx;
  color: #94A3B8;
  flex-shrink: 0;
}

.search-input-small {
  flex: 1;
  font-size: 28rpx;
  color: #0F172A;
}

.search-clear-small {
  font-size: 28rpx;
  color: rgba(148, 163, 184, 0.9);
  padding: 6rpx;
  flex-shrink: 0;
}

/* 线索卡片（复用全局 list-card，仅补小差异） */
.lead-list {
  margin-bottom: 24rpx;
}

.lead-card {
  margin-bottom: 24rpx;
  transition: all 0.3s ease;
}

.lead-card:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.15);
}

.list-phone {
  font-size: 24rpx;
  color: rgba(148, 163, 184, 0.95);
  font-weight: 700;
  margin-top: 6rpx;
 }

/* 悬浮新增按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: calc(var(--tabbar-height) + env(safe-area-inset-bottom) + 28rpx);
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.4);
  z-index: 100;
  transition: all 0.3s ease;
}

.fab-btn:active {
  transform: scale(0.9);
  box-shadow: 0 4rpx 12rpx rgba(14, 165, 233, 0.5);
}

.fab-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fab-plus {
  width: 48rpx;
  height: 48rpx;
  position: relative;
}

.fab-plus::before,
.fab-plus::after {
  content: '';
  position: absolute;
  background-color: #fff;
}

.fab-plus::before {
  width: 100%;
  height: 6rpx;
  top: 50%;
  left: 0;
  transform: translateY(-50%);
  border-radius: 3rpx;
}

.fab-plus::after {
  width: 6rpx;
  height: 100%;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  border-radius: 3rpx;
}

/* 加载和空状态 */
.loading, .no-more {
  text-align: center;
  padding: 30rpx;
  color: #94A3B8;
  font-size: 26rpx;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #94A3B8;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
  opacity: 0.45;
}
