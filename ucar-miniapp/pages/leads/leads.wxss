page {
  background: transparent;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.page {
  padding: 24rpx;
  padding-bottom: 140rpx;
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* 主次分组Tab */
.lead-filter-bar {
  padding: 16rpx 20rpx;
  margin-bottom: 24rpx;
  position: relative;
}

.lead-filter-list {
  display: flex;
  gap: 12rpx;
}

.lead-filter-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  padding: 0 18rpx;
  font-size: 26rpx;
  color: rgba(71, 85, 105, 0.92);
  border-radius: 24rpx;
  font-weight: 700;
  transition: all 0.3s ease;
  background: rgba(255, 255, 255, 0.52);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.lead-filter-item.active {
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(14, 165, 233, 0.3);
}

.lead-filter-item.more {
  gap: 8rpx;
}

.tab-more-icon {
  font-size: 24rpx;
  transition: transform 0.15s ease;
}

.tab-more-icon.up {
  transform: rotate(180deg);
}

/* 更多下拉面板 */
.more-dropdown {
  position: absolute;
  top: 100%;
  left: 20rpx;
  right: 20rpx;
  margin-top: 8rpx;
  z-index: 1000;
}

.more-dropdown-mask {
  position: fixed;
  inset: 0;
  z-index: 999;
}

.more-dropdown-panel {
  position: relative;
  z-index: 1000;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.dropdown-item {
  height: 72rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: rgba(71, 85, 105, 0.92);
  font-weight: 600;
}

.dropdown-item.active {
  background: rgba(14, 165, 233, 0.12);
  color: #0369A1;
}

/* 筛选区域 */
.search-section {
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.search-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.search-label {
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: rgba(241, 245, 249, 0.8);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  gap: 12rpx;
}

.search-icon-small {
  font-size: 32rpx;
  color: #94A3B8;
  flex-shrink: 0;
}

.search-input-small {
  flex: 1;
  font-size: 28rpx;
  color: #0F172A;
}

.search-clear-small {
  font-size: 28rpx;
  color: rgba(148, 163, 184, 0.9);
  padding: 6rpx;
  flex-shrink: 0;
}

/* 线索卡片 */
.lead-list {
  margin-bottom: 24rpx;
}

.lead-card {
  margin-bottom: 24rpx;
  transition: all 0.3s ease;
  position: relative;
}

.lead-card:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.15);
}

.lead-card.overdue {
  border-left: 4rpx solid #EF4444;
}

.list-phone {
  font-size: 24rpx;
  color: rgba(148, 163, 184, 0.95);
  font-weight: 700;
  margin-top: 6rpx;
}

/* 跟进摘要 */
.followup-summary {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(226, 232, 240, 0.6);
  font-size: 24rpx;
}

.followup-summary .icon-sm {
  font-size: 24rpx;
  flex-shrink: 0;
}

.summary-text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

/* 悬浮新增按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: calc(var(--tabbar-height) + env(safe-area-inset-bottom) + 28rpx);
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.4);
  z-index: 100;
  transition: all 0.3s ease;
}

.fab-btn:active {
  transform: scale(0.9);
  box-shadow: 0 4rpx 12rpx rgba(14, 165, 233, 0.5);
}

.fab-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fab-plus {
  width: 48rpx;
  height: 48rpx;
  position: relative;
}

.fab-plus::before,
.fab-plus::after {
  content: '';
  position: absolute;
  background-color: #fff;
}

.fab-plus::before {
  width: 100%;
  height: 6rpx;
  top: 50%;
  left: 0;
  transform: translateY(-50%);
  border-radius: 3rpx;
}

.fab-plus::after {
  width: 6rpx;
  height: 100%;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  border-radius: 3rpx;
}

/* 加载和空状态 */
.loading, .no-more {
  text-align: center;
  padding: 30rpx;
  color: #94A3B8;
  font-size: 26rpx;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #94A3B8;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
  opacity: 0.45;
}
