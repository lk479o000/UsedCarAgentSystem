page {
  background: #F1F5F9;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.container {
  padding: 24rpx;
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 12rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #E2E8F0;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #94A3B8;
  border-radius: 24rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.filter-item.active {
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(14, 165, 233, 0.3);
}

/* 线索卡片 */
.lead-list {
  margin-bottom: 24rpx;
}

.lead-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #E2E8F0;
  transition: all 0.3s ease;
}

.lead-card:active {
  transform: scale(0.98);
}

.lead-header {
  margin-bottom: 20rpx;
}

.customer-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.customer-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #0F172A;
  letter-spacing: -0.02em;
}

.customer-phone {
  font-size: 26rpx;
  color: #94A3B8;
  font-weight: 500;
}

/* 状态标签 */
.lead-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.lead-status.tag-primary {
  background: rgba(14, 165, 233, 0.1);
  color: #0369A1;
}

.lead-status.tag-success {
  background: rgba(20, 184, 166, 0.1);
  color: #14B8A6;
}

.lead-status.tag-warning {
  background: rgba(245, 158, 11, 0.1);
  color: #F59E0B;
}

.lead-status.tag-danger {
  background: rgba(239, 68, 68, 0.1);
  color: #EF4444;
}

/* 车辆信息 */
.car-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #E2E8F0;
  border-bottom: 1rpx solid #E2E8F0;
  margin-bottom: 20rpx;
}

.car-label {
  font-size: 24rpx;
  color: #94A3B8;
  background: #F1F5F9;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.car-value {
  font-size: 28rpx;
  color: #0F172A;
  font-weight: 500;
}

/* 备注 */
.lead-footer {
  display: flex;
  gap: 8rpx;
}

.notes-label {
  font-size: 24rpx;
  color: #94A3B8;
  font-weight: 500;
  flex-shrink: 0;
}

.notes-value {
  font-size: 24rpx;
  color: #475569;
  line-height: 1.5;
}

/* 加载和空状态 */
.loading, .no-more {
  text-align: center;
  padding: 30rpx;
  color: #94A3B8;
  font-size: 26rpx;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #94A3B8;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
  opacity: 0.5;
}
