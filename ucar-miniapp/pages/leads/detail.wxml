<view class="aura-page" wx:if="{{lead}}">
  <view class="aura-bg"></view>
  <view class="aura-content with-actionbar">
  <!-- 基本信息区域 -->
  <view class="card-glass list-card mb-4">
    <view class="flex justify-between items-start">
      <view class="flex flex-col gap-2">
        <text class="list-title">{{lead.customerName}}</text>
        <view class="flex items-center gap-2">
          <view class="tag-info">{{lead.customerTypeText}}</view>
          <view class="tag-{{lead.statusType}}">{{lead.statusText}}</view>
        </view>
      </view>
    </view>

    <view class="list-meta">
      <view class="chip">
        <view class="i-lucide-phone text-primary"></view>
        <text>{{lead.displayPhone}}</text>
      </view>
      <view class="chip" wx:if="{{lead.carBrand || lead.carModel}}">
        <view class="i-lucide-car text-primary"></view>
        <text>{{(lead.carBrand || '') + ' ' + (lead.carModel || '')}}</text>
      </view>
      <view class="chip" wx:if="{{lead.createdAt}}">
        <view class="i-lucide-calendar text-primary"></view>
        <text>{{lead.createdAt}}</text>
      </view>
      <view class="chip" wx:if="{{isAdmin}}">
        <view class="i-lucide-user text-primary"></view>
        <text>{{lead.agentName || '-'}}</text>
      </view>
    </view>

    <view class="note-block">
      <view class="note-title">备注</view>
      <view class="note-text">{{lead.notes || '-'}}</view>
    </view>
  </view>

  <!-- 跟进记录区域（仅管理员） -->
  <view class="card-glass p-4 mb-4" wx:if="{{isAdmin}}">
    <view class="flex justify-between items-center mb-4">
      <text class="text-lg font-bold text-gray-800">跟进记录</text>
      <view class="flex items-center gap-1 text-primary text-sm" bindtap="onAddFollowup">
        <view class="i-lucide-plus text-sm"></view>
        <text>新增</text>
      </view>
    </view>

    <view wx:if="{{followups.length > 0}}">
      <view class="bg-gray-50 rounded-xl p-4 mb-3" wx:for="{{followups}}" wx:key="id">
        <view class="flex justify-between items-center mb-2">
          <text class="text-sm font-semibold text-gray-800">{{item.operatorName || '管理员'}}</text>
          <view class="flex gap-3">
            <text class="text-sm text-primary" bindtap="onEditFollowup" data-id="{{item.id}}">编辑</text>
            <text class="text-sm text-red-500" bindtap="onDeleteFollowup" data-id="{{item.id}}">删除</text>
          </view>
        </view>
        <view class="text-xs text-gray-400 mb-1">跟进时间：{{item.followUpTime}}</view>
        <view class="text-sm text-gray-700 mb-1">{{item.content}}</view>
        <view class="text-sm text-gray-600" wx:if="{{item.result}}">结果：{{item.result}}</view>
        <view class="text-xs text-gray-400" wx:if="{{item.nextFollowUpTime}}">下次跟进：{{item.nextFollowUpTime}}</view>
      </view>
    </view>
    <view wx:else class="text-center text-sm text-gray-400 py-6">暂无跟进记录</view>
  </view>

  <!-- 底部占位 -->
  <view class="h-24" wx:if="{{isAdmin}}"></view>

  <!-- 底部操作栏（仅管理员） -->
  <view class="detail-actionbar-wrap" wx:if="{{isAdmin}}">
    <view class="detail-actionbar card-glass">
      <view class="detail-action" bindtap="onEdit">
        <view class="detail-action-icon i-lucide-edit"></view>
        <text class="detail-action-text">编辑</text>
      </view>
      <view class="detail-action primary" bindtap="onUpdateStatus" wx:if="{{lead.status !== 4 && lead.status !== 5}}">
        <view class="detail-action-icon i-lucide-activity"></view>
        <text class="detail-action-text">更新状态</text>
      </view>
      <view class="detail-action success" bindtap="onSettlement" wx:if="{{lead.status === 4 && !hasSettlement}}">
        <view class="detail-action-icon i-lucide-wallet"></view>
        <text class="detail-action-text">结算</text>
      </view>
      <view class="detail-action warning" bindtap="onReSettlement" wx:if="{{lead.status === 4 && hasSettlement}}">
        <view class="detail-action-icon i-lucide-wallet"></view>
        <text class="detail-action-text">重新结算</text>
      </view>
      <view class="detail-action danger" bindtap="onDelete">
        <view class="detail-action-icon i-lucide-trash-2"></view>
        <text class="detail-action-text">删除</text>
      </view>
    </view>
  </view>

  <!-- 更新状态 ActionSheet（玻璃拟态） -->
  <view class="sheet-mask" wx:if="{{showStatusSheet}}" bindtap="closeStatusSheet"></view>
  <view class="sheet-wrap" wx:if="{{showStatusSheet}}">
    <view class="sheet card-glass" catchtap="noop">
      <view class="sheet-title">选择新状态</view>
      <view class="sheet-list">
        <view class="sheet-item" wx:for="{{statusOptions}}" wx:key="value" bindtap="onStatusSelect" data-value="{{item.value}}">
          <text class="sheet-item-text">{{item.label}}</text>
        </view>
      </view>
      <view class="sheet-cancel" bindtap="closeStatusSheet">取消</view>
    </view>
  </view>

  <!-- 成交价格输入弹窗（玻璃拟态） -->
  <view class="dialog-mask" wx:if="{{showDealInput}}" bindtap="closeDealInput"></view>
  <view class="dialog card-glass" wx:if="{{showDealInput}}" catchtap="noop">
    <view class="dialog-title">填写成交价格</view>
    <input class="dialog-input" type="digit" placeholder="请输入成交价格" value="{{dealPrice}}" bindinput="onDealPriceInput" />
    <view class="dialog-actions">
      <button class="dialog-btn ghost" bindtap="closeDealInput">取消</button>
      <button class="dialog-btn primary" bindtap="onConfirmDeal">确定</button>
    </view>
  </view>

  <!-- 失败原因输入弹窗（玻璃拟态） -->
  <view class="dialog-mask" wx:if="{{showFailInput}}" bindtap="closeFailInput"></view>
  <view class="dialog card-glass" wx:if="{{showFailInput}}" catchtap="noop">
    <view class="dialog-title">填写失败原因</view>
    <input class="dialog-input" placeholder="请输入失败原因" value="{{failReason}}" bindinput="onFailReasonInput" />
    <view class="dialog-actions">
      <button class="dialog-btn ghost" bindtap="closeFailInput">取消</button>
      <button class="dialog-btn primary" bindtap="onConfirmFail">确定</button>
    </view>
  </view>
  </view>
</view>

<view class="flex items-center justify-center h-screen text-gray-400" wx:if="{{loading}}">加载中...</view>
