<view class="page p-4">
  <view class="card-glass p-4">
    <view class="mb-5">
      <text class="text-sm font-semibold text-gray-800 mb-2 block">客户姓名 <text class="text-red-500">*</text></text>
      <input class="border border-gray-200 rounded-xl px-4 py-3 text-base" placeholder="请输入客户姓名" value="{{customerName}}" bindinput="onCustomerNameInput" />
    </view>

    <view class="mb-5">
      <text class="text-sm font-semibold text-gray-800 mb-2 block">客户电话 <text class="text-red-500">*</text></text>
      <input class="border border-gray-200 rounded-xl px-4 py-3 text-base" type="number" maxlength="11" placeholder="请输入11位手机号" value="{{customerPhone}}" bindinput="onCustomerPhoneInput" />
    </view>

    <view class="mb-5">
      <text class="text-sm font-semibold text-gray-800 mb-2 block">客户类型 <text class="text-red-500">*</text></text>
      <picker range="{{customerTypeOptions}}" value="{{customerTypeIndex}}" bindchange="onCustomerTypeChange">
        <view class="border border-gray-200 rounded-xl px-4 py-3 text-base flex justify-between items-center">
          <text>{{customerTypeText}}</text>
          <view class="i-lucide-chevron-down text-gray-400"></view>
        </view>
      </picker>
    </view>

    <view class="mb-5">
      <text class="text-sm font-semibold text-gray-800 mb-2 block">车辆品牌</text>
      <input class="border border-gray-200 rounded-xl px-4 py-3 text-base" placeholder="请输入车辆品牌" value="{{carBrand}}" bindinput="onCarBrandInput" />
    </view>

    <view class="mb-5">
      <text class="text-sm font-semibold text-gray-800 mb-2 block">车辆型号 <text class="text-red-500">*</text></text>
      <input class="border border-gray-200 rounded-xl px-4 py-3 text-base" placeholder="请输入车辆型号" value="{{carModel}}" bindinput="onCarModelInput" />
    </view>

    <view class="mb-5" wx:if="{{!isEdit}}">
      <text class="text-sm font-semibold text-gray-800 mb-2 block">归属经纪人 <text class="text-red-500">*</text></text>
      <picker range="{{agentNames}}" value="{{agentIndex}}" bindchange="onAgentChange">
        <view class="border border-gray-200 rounded-xl px-4 py-3 text-base flex justify-between items-center">
          <text>{{agentNames[agentIndex] || '请选择经纪人'}}</text>
          <view class="i-lucide-chevron-down text-gray-400"></view>
        </view>
      </picker>
    </view>
    <view class="mb-5" wx:if="{{isEdit}}">
      <text class="text-sm font-semibold text-gray-800 mb-2 block">归属经纪人</text>
      <view class="border border-gray-200 rounded-xl px-4 py-3 text-base text-gray-500 bg-gray-50">{{agentName || '-'}}</view>
    </view>

    <view class="mb-5">
      <text class="text-sm font-semibold text-gray-800 mb-2 block">备注</text>
      <textarea class="border border-gray-200 rounded-xl px-4 py-3 text-base" placeholder="请输入备注（最多200字）" maxlength="200" value="{{notes}}" bindinput="onNotesInput" style="min-height: 160rpx;" />
    </view>
  </view>

  <view class="h-8"></view>

  <button class="btn-primary w-full py-4 text-base font-semibold" loading="{{submitting}}" bindtap="onSubmit">
    {{isEdit ? '保存修改' : '确定新增'}}
  </button>
</view>
