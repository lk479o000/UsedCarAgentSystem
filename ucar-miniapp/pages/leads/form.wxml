<view class="aura-page with-actionbar">
  <view class="aura-bg"></view>
  <view class="aura-content">
  <view class="card-glass form-card">
    <view class="form-item">
      <text class="form-label">客户姓名 <text class="form-required">*</text></text>
      <view class="form-control">
        <input class="form-input" placeholder-class="form-placeholder" placeholder="请输入客户姓名" value="{{customerName}}" bindinput="onCustomerNameInput" />
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">客户电话 <text class="form-required">*</text></text>
      <view class="form-control">
        <input class="form-input" placeholder-class="form-placeholder" type="number" maxlength="11" placeholder="请输入11位手机号" value="{{customerPhone}}" bindinput="onCustomerPhoneInput" />
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">客户类型 <text class="form-required">*</text></text>
      <picker range="{{customerTypeOptions}}" value="{{customerTypeIndex}}" bindchange="onCustomerTypeChange">
        <view class="form-control">
          <text>{{customerTypeText}}</text>
          <view class="i-lucide-chevron-down text-gray-400"></view>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">车辆品牌</text>
      <view class="form-control">
        <input class="form-input" placeholder-class="form-placeholder" placeholder="请输入车辆品牌" value="{{carBrand}}" bindinput="onCarBrandInput" />
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">车辆型号 <text class="form-required">*</text></text>
      <view class="form-control">
        <input class="form-input" placeholder-class="form-placeholder" placeholder="请输入车辆型号" value="{{carModel}}" bindinput="onCarModelInput" />
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">所属省份</text>
      <picker range="{{provinceNames}}" value="{{provinceIndex}}" bindchange="onProvinceChange">
        <view class="form-control">
          <text>{{provinceNames[provinceIndex] || '请选择省份'}}</text>
          <view class="i-lucide-chevron-down text-gray-400"></view>
        </view>
      </picker>
    </view>

    <view class="form-item" wx:if="{{cityNames.length > 0}}">
      <text class="form-label">所属城市</text>
      <picker range="{{cityNames}}" value="{{cityIndex}}" bindchange="onCityChange">
        <view class="form-control">
          <text>{{cityNames[cityIndex] || '请选择城市'}}</text>
          <view class="i-lucide-chevron-down text-gray-400"></view>
        </view>
      </picker>
    </view>

    <view class="form-item" wx:if="{{districtNames.length > 0}}">
      <text class="form-label">所属区县</text>
      <picker range="{{districtNames}}" value="{{districtIndex}}" bindchange="onDistrictChange">
        <view class="form-control">
          <text>{{districtNames[districtIndex] || '请选择区县'}}</text>
          <view class="i-lucide-chevron-down text-gray-400"></view>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">归属经纪人 <text class="form-required">*</text></text>
      <picker range="{{agentNames}}" value="{{agentIndex}}" bindchange="onAgentChange">
        <view class="form-control">
          <text>{{agentNames[agentIndex] || '请选择经纪人'}}</text>
          <view class="i-lucide-chevron-down text-gray-400"></view>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">备注</text>
      <textarea class="form-textarea" placeholder-class="form-placeholder" placeholder="请输入备注（最多200字）" maxlength="200" value="{{notes}}" bindinput="onNotesInput" />
    </view>
  </view>
  </view>
</view>

<view class="form-actionbar-wrap">
  <view class="form-actionbar card-glass">
    <button class="btn-primary form-action-btn" loading="{{submitting}}" bindtap="onSubmit">
      {{isEdit ? '保存修改' : '确定新增'}}
    </button>
  </view>
</view>
