<view class="page p-4">
  <!-- 筛选栏 - 横向滚动 -->
  <scroll-view class="filter-bar card-glass" scroll-x enable-flex>
    <view
      class="filter-item {{filterStatus === item.value ? 'active' : ''}}"
      wx:for="{{statusOptions}}"
      wx:key="value"
      bindtap="changeFilter"
      data-status="{{item.value}}"
    >
      {{item.label}}
    </view>
  </scroll-view>

  <!-- 搜索栏 -->
  <view class="search-bar card-glass">
    <view class="i-lucide-search search-icon"></view>
    <input
      class="search-input"
      placeholder="搜索客户姓名"
      value="{{searchKeyword}}"
      bindinput="onSearchInput"
      bindconfirm="onSearch"
      confirm-type="search"
    />
  </view>

  <!-- 线索列表 -->
  <view class="lead-list" wx:if="{{list.length > 0}}">
    <view class="lead-card card-glass" wx:for="{{list}}" wx:key="id" bindtap="onCardTap" data-id="{{item.id}}">
      <view class="lead-header">
        <view class="customer-wrap">
          <text class="customer-name">{{item.customerName}}</text>
          <view class="lead-status tag-{{item.statusType}}">{{item.statusText}}</view>
        </view>
        <text class="customer-phone">{{item.displayPhone}}</text>
      </view>

      <view class="car-info">
        <text class="car-label" wx:if="{{item.carBrand}}">{{item.carBrand}}</text>
        <text class="car-value">{{item.carModel}}</text>
      </view>

      <view class="lead-footer">
        <text class="agent-name" wx:if="{{isAdmin && item.agentName}}">经纪人：{{item.agentName}}</text>
        <text class="create-time">{{item.createdAt}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && list.length === 0}}" class="empty">
    <text class="empty-icon">📭</text>
    <text>暂无线索</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">加载中...</view>
  <view class="no-more" wx:if="{{!hasMore && list.length > 0}}">没有更多了</view>

  <!-- 管理员新增按钮 -->
  <view class="fab-btn" wx:if="{{isAdmin}}" bindtap="onAddLead">
    <view class="i-lucide-plus fab-icon"></view>
  </view>
</view>
