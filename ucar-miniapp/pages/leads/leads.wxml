<view class="aura-page with-tabbar">
  <view class="aura-bg"></view>
  <view class="aura-content">
  <guest-tip wx:if="{{isGuest}}" tip-text="登录后可查看线索列表与详情" />

  <!-- 筛选栏 - 折叠面板 -->
  <view class="filter-panel card-glass">
    <view class="filter-head" bindtap="toggleFilterPanel">
      <view class="filter-head-left">
        <view class="i-lucide-sliders-horizontal filter-head-icon"></view>
        <text class="filter-head-title">状态筛选</text>
      </view>
      <view class="filter-head-right">
        <view class="filter-current">{{currentStatusLabel}}</view>
        <view class="i-lucide-chevron-down filter-head-arrow {{showFilterPanel ? 'up' : ''}}"></view>
      </view>
    </view>
    <view class="filter-body" wx:if="{{showFilterPanel}}">
      <view
        class="filter-chip {{filterStatus === item.value ? 'active' : ''}}"
        wx:for="{{statusOptions}}"
        wx:key="value"
        bindtap="changeFilter"
        data-status="{{item.value}}"
      >
        {{item.label}}
      </view>
    </view>
  </view>

  <!-- 筛选框区域 -->
  <view class="search-section card-glass">
    <view wx:if="{{isAdmin}}">
      <view class="search-item">
        <view class="search-label">经纪人</view>
        <view class="search-input-wrap">
          <view class="i-lucide-search search-icon-small"></view>
          <input
            class="search-input-small"
            placeholder="姓名/手机号"
            value="{{agentKeyword}}"
            bindinput="onAgentKeywordInput"
            bindconfirm="onSearch"
            confirm-type="search"
          />
          <view class="i-lucide-x search-clear-small" wx:if="{{agentKeyword}}" bindtap="onClearAgentKeyword"></view>
        </view>
      </view>
    </view>
    <view class="search-item">
      <view class="search-label">客户</view>
      <view class="search-input-wrap">
        <view class="i-lucide-search search-icon-small"></view>
        <input
          class="search-input-small"
          placeholder="姓名/手机号"
          value="{{customerKeyword}}"
          bindinput="onCustomerKeywordInput"
          bindconfirm="onSearch"
          confirm-type="search"
        />
        <view class="i-lucide-x search-clear-small" wx:if="{{customerKeyword}}" bindtap="onClearCustomerKeyword"></view>
      </view>
    </view>
  </view>

  <!-- 线索列表 -->
  <view class="lead-list" wx:if="{{list.length > 0}}">
    <view class="card-glass list-card lead-card" wx:for="{{list}}" wx:key="id" bindtap="onCardTap" data-id="{{item.id}}">
      <view class="flex justify-between items-start">
        <view class="flex flex-col gap-2">
          <view class="flex items-center gap-2">
            <text class="list-title">{{item.customerName}}</text>
            <view class="tag-info" wx:if="{{item.customerTypeText}}">{{item.customerTypeText}}</view>
            <view class="tag-{{item.statusType}}">{{item.statusText}}</view>
          </view>
          <text class="list-subtitle">{{item.carText}}</text>
        </view>
        <text class="list-phone">{{item.displayPhone}}</text>
      </view>

      <view class="list-meta">
        <view class="chip" wx:if="{{isAdmin && item.agentName}}">
          <view class="i-lucide-user text-primary"></view>
          <text>经纪人 {{item.agentName}}</text>
        </view>
        <view class="chip" wx:if="{{item.regionText}}">
          <view class="i-lucide-map-pin text-primary"></view>
          <text>{{item.regionText}}</text>
        </view>
        <view class="chip" wx:if="{{item.createdAt}}">
          <view class="i-lucide-clock text-primary"></view>
          <text>{{item.createdAt}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && list.length === 0}}" class="empty">
    <view class="i-lucide-inbox empty-icon"></view>
    <text wx:if="{{isGuest}}">登录后可查看线索</text>
    <text wx:elif="{{agentKeyword || customerKeyword}}">未找到匹配结果</text>
    <text wx:else>暂无线索</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">加载中...</view>
  <view class="no-more" wx:if="{{!hasMore && list.length > 0}}">没有更多了</view>

  <!-- 管理员新增按钮 -->
  <view class="fab-btn" wx:if="{{isAdmin}}" bindtap="onAddLead">
    <view class="fab-icon">
      <view class="fab-plus"></view>
    </view>
  </view>
  </view>
</view>
