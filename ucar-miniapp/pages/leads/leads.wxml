<view class="page p-4">
  <!-- 筛选栏 -->
  <view class="filter-bar card-glass">
    <view class="filter-item {{filterStatus === '' ? 'active' : ''}}" bindtap="changeFilter" data-status="">全部</view>
    <view class="filter-item {{filterStatus === '0' ? 'active' : ''}}" bindtap="changeFilter" data-status="0">待跟进</view>
    <view class="filter-item {{filterStatus === '1' ? 'active' : ''}}" bindtap="changeFilter" data-status="1">跟进中</view>
    <view class="filter-item {{filterStatus === '4' ? 'active' : ''}}" bindtap="changeFilter" data-status="4">已成交</view>
  </view>

  <!-- 线索列表 -->
  <view class="lead-list" wx:if="{{leads.length > 0}}">
    <view class="lead-card card-glass" wx:for="{{leads}}" wx:key="id">
      <view class="lead-header">
        <view class="customer-wrap">
          <text class="customer-name">{{item.customerName}}</text>
          <view class="lead-status tag-{{item.statusType}}">{{item.statusText}}</view>
        </view>
        <text class="customer-phone">{{item.customerPhone}}</text>
      </view>

      <view class="car-info">
        <text class="car-label">{{item.carBrand}}</text>
        <text class="car-value">{{item.carModel}}</text>
      </view>

      <view class="lead-footer" wx:if="{{item.notes}}">
        <text class="notes-label">备注：</text>
        <text class="notes-value">{{item.notes}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty">
    <text class="empty-icon">📭</text>
    <text>暂无线索</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading && leads.length > 0}}">加载中...</view>
  <view class="no-more" wx:if="{{!hasMore && leads.length > 0}}">没有更多了</view>
</view>
