<view class="aura-page" wx:if="{{settlement}}">
  <view class="aura-bg"></view>
  <view class="aura-content with-actionbar">
  <view class="card-glass list-card mb-4">
    <view class="flex justify-between items-start">
      <view class="flex flex-col gap-2">
        <text class="list-title">{{settlement.lead.customerName}}</text>
        <text class="list-subtitle">{{settlement.carText}}</text>
      </view>
      <view class="tag-{{settlement.statusType}}">{{settlement.statusText}}</view>
    </view>

    <view class="list-meta">
      <view class="chip">
        <view class="i-lucide-phone text-primary"></view>
        <text>{{settlement.displayCustomerPhone}}</text>
      </view>
      <view class="chip" wx:if="{{settlement.lead.agentName}}">
        <view class="i-lucide-user text-primary"></view>
        <text>{{settlement.lead.agentName}}</text>
      </view>
      <view class="chip" wx:if="{{settlement.lead.agentPhone}}">
        <view class="i-lucide-phone text-primary"></view>
        <text>{{settlement.displayAgentPhone}}</text>
      </view>
    </view>

    <view class="list-meta">
      <view class="chip primary">
        <text>利润 ¥{{settlement.profit}}</text>
      </view>
      <view class="chip success">
        <text>分成 ¥{{settlement.agentShare}}</text>
      </view>
      <view class="chip" wx:if="{{settlement.settledAt}}">
        <view class="i-lucide-calendar text-primary"></view>
        <text>结算 {{settlement.settledAt}}</text>
      </view>
      <view class="chip" wx:if="{{settlement.createdAt}}">
        <view class="i-lucide-clock text-primary"></view>
        <text>创建 {{settlement.createdAt}}</text>
      </view>
    </view>

    <view class="note-block">
      <view class="note-title">备注</view>
      <view class="note-text">{{settlement.notes || '-'}}</view>
    </view>
  </view>

  <!-- 底部占位 -->
  <view class="h-24" wx:if="{{isAdmin}}"></view>

  <!-- 底部操作栏（仅管理员） -->
  <view class="detail-actionbar-wrap" wx:if="{{isAdmin}}">
    <view class="detail-actionbar card-glass">
      <view class="detail-action" bindtap="onEdit">
        <view class="detail-action-icon i-lucide-edit"></view>
        <text class="detail-action-text">编辑</text>
      </view>
      <view class="detail-action primary" bindtap="onUpdateStatus">
        <view class="detail-action-icon i-lucide-activity"></view>
        <text class="detail-action-text">更新状态</text>
      </view>
    </view>
  </view>

  <!-- 更新状态 ActionSheet -->
  <view class="sheet-mask" wx:if="{{showStatusSheet}}" bindtap="closeStatusSheet"></view>
  <view class="sheet-wrap" wx:if="{{showStatusSheet}}">
    <view class="sheet card-glass" catchtap="noop">
      <view class="sheet-title">选择状态</view>
      <view class="sheet-list">
        <view class="sheet-item" bindtap="onStatusSelect" data-status="0">
          <text class="sheet-item-text">待结算</text>
        </view>
        <view class="sheet-item" bindtap="onStatusSelect" data-status="1">
          <text class="sheet-item-text">已结算</text>
        </view>
      </view>
      <view class="sheet-cancel" bindtap="closeStatusSheet">取消</view>
    </view>
  </view>

  <!-- 结算时间弹窗 -->
  <view class="dialog-mask" wx:if="{{showSettleDialog}}" bindtap="closeSettleDialog"></view>
  <view class="dialog card-glass" wx:if="{{showSettleDialog}}" catchtap="noop">
    <view class="dialog-title">选择结算时间</view>
    <picker mode="date" value="{{settledAt}}" bindchange="onSettledAtChange">
      <view class="form-control">
        <text class="{{settledAt ? '' : 'form-placeholder'}}">{{settledAt || '请选择日期'}}</text>
        <view class="i-lucide-calendar text-gray-400"></view>
      </view>
    </picker>
    <view class="dialog-actions">
      <button class="dialog-btn ghost" bindtap="closeSettleDialog">取消</button>
      <button class="dialog-btn primary" bindtap="onConfirmSettle">确定</button>
    </view>
  </view>
  </view>
</view>

<view class="flex items-center justify-center h-screen text-gray-400" wx:if="{{loading}}">加载中...</view>
