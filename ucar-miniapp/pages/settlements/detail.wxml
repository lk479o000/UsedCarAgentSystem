<view class="page p-4" wx:if="{{settlement}}">
  <view class="card-glass p-4 mb-4">
    <view class="flex justify-between items-center py-3 border-b border-solid border-gray-100">
      <text class="text-sm text-gray-400 w-20 shrink-0">客户姓名</text>
      <text class="text-base font-semibold text-gray-800">{{settlement.lead.customerName}}</text>
    </view>
    <view class="flex justify-between items-center py-3 border-b border-solid border-gray-100">
      <text class="text-sm text-gray-400 w-20 shrink-0">车辆品牌</text>
      <text class="text-base text-gray-800">{{settlement.lead.carBrand || '-'}}</text>
    </view>
    <view class="flex justify-between items-center py-3 border-b border-solid border-gray-100">
      <text class="text-sm text-gray-400 w-20 shrink-0">车辆型号</text>
      <text class="text-base text-gray-800">{{settlement.lead.carModel || '-'}}</text>
    </view>
    <view class="flex justify-between items-center py-3 border-b border-solid border-gray-100">
      <text class="text-sm text-gray-400 w-20 shrink-0">利润金额</text>
      <text class="text-base font-bold text-gray-800">¥{{settlement.profit}}</text>
    </view>
    <view class="flex justify-between items-center py-3 border-b border-solid border-gray-100">
      <text class="text-sm text-gray-400 w-20 shrink-0">经纪人分成</text>
      <text class="text-base font-bold text-primary">¥{{settlement.agentShare}}</text>
    </view>
    <view class="flex justify-between items-center py-3 border-b border-solid border-gray-100">
      <text class="text-sm text-gray-400 w-20 shrink-0">状态</text>
      <view class="tag-{{settlement.statusType}}">{{settlement.statusText}}</view>
    </view>
    <view class="flex justify-between items-center py-3 border-b border-solid border-gray-100">
      <text class="text-sm text-gray-400 w-20 shrink-0">结算时间</text>
      <text class="text-sm text-gray-500">{{settlement.settledAt || '-'}}</text>
    </view>
    <view class="flex justify-between items-start py-3 border-b border-solid border-gray-100">
      <text class="text-sm text-gray-400 w-20 shrink-0">备注</text>
      <text class="text-base text-gray-600 flex-1 text-right">{{settlement.notes || '-'}}</text>
    </view>
    <view class="flex justify-between items-center py-3">
      <text class="text-sm text-gray-400 w-20 shrink-0">创建时间</text>
      <text class="text-sm text-gray-500">{{settlement.createdAt}}</text>
    </view>
  </view>

  <!-- 底部占位 -->
  <view class="h-24" wx:if="{{isAdmin}}"></view>

  <!-- 底部操作栏（仅管理员） -->
  <view class="fixed bottom-0 left-0 right-0 bg-white shadow-lg flex items-center justify-around py-3 px-2 z-100" wx:if="{{isAdmin}}" style="padding-bottom: env(safe-area-inset-bottom);">
    <view class="flex flex-col items-center gap-1 text-sm text-gray-600" bindtap="onEdit">
      <view class="i-lucide-edit text-lg"></view>
      <text>编辑</text>
    </view>
    <view class="flex flex-col items-center gap-1 text-sm text-primary" bindtap="onUpdateStatus">
      <view class="i-lucide-activity text-lg"></view>
      <text>更新状态</text>
    </view>
  </view>

  <!-- 更新状态 ActionSheet -->
  <view class="fixed inset-0 bg-black bg-opacity-50 z-200" wx:if="{{showStatusSheet}}" bindtap="closeStatusSheet"></view>
  <view class="fixed bottom-0 left-0 right-0 bg-white rounded-t-2xl z-300" wx:if="{{showStatusSheet}}">
    <view class="text-center text-base font-semibold text-gray-800 py-4 border-b border-gray-100">选择状态</view>
    <view class="text-center py-4 text-base text-gray-700" bindtap="onStatusSelect" data-status="0">待结算</view>
    <view class="text-center py-4 text-base text-gray-700" bindtap="onStatusSelect" data-status="1">已结算</view>
    <view class="text-center py-4 text-base text-gray-400 border-t border-gray-100" bindtap="closeStatusSheet">取消</view>
  </view>

  <!-- 结算时间弹窗 -->
  <view class="fixed inset-0 bg-black bg-opacity-50 z-200" wx:if="{{showSettleDialog}}" bindtap="closeSettleDialog"></view>
  <view class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-white rounded-2xl z-300 p-6" wx:if="{{showSettleDialog}}" style="width: 80%;">
    <view class="text-lg font-bold text-gray-800 text-center mb-4">选择结算时间</view>
    <picker mode="date" value="{{settledAt}}" bindchange="onSettledAtChange">
      <view class="border border-gray-200 rounded-xl px-4 py-3 text-base flex justify-between items-center">
        <text>{{settledAt || '请选择日期'}}</text>
        <view class="i-lucide-calendar text-gray-400"></view>
      </view>
    </picker>
    <view class="flex gap-3 mt-6">
      <view class="flex-1 text-center py-3 rounded-xl bg-gray-100 text-gray-600 text-base" bindtap="closeSettleDialog">取消</view>
      <view class="flex-1 text-center py-3 rounded-xl btn-primary text-white text-base" bindtap="onConfirmSettle">确定</view>
    </view>
  </view>
</view>

<view class="flex items-center justify-center h-screen text-gray-400" wx:if="{{loading}}">加载中...</view>
