<view class="aura-page with-tabbar">
  <view class="aura-bg"></view>
  <view class="aura-content">
  <guest-tip wx:if="{{isGuest}}" tip-text="登录后可查看结算列表与详情" />

  <!-- 筛选栏 -->
  <view class="filter-bar card-glass">
    <view class="filter-item {{filterStatus === '' ? 'active' : ''}}" bindtap="changeFilter" data-status="">全部</view>
    <view class="filter-item {{filterStatus === '0' ? 'active' : ''}}" bindtap="changeFilter" data-status="0">待结算</view>
    <view class="filter-item {{filterStatus === '1' ? 'active' : ''}}" bindtap="changeFilter" data-status="1">已结算</view>
  </view>

  <!-- 筛选框区域 -->
  <view class="search-section card-glass">
    <!-- 管理员：两个筛选框 -->
    <view wx:if="{{isAdmin}}">
      <!-- 经纪人筛选框 -->
      <view class="search-item">
        <view class="search-label">经纪人</view>
        <view class="search-input-wrap">
          <view class="i-lucide-search search-icon-small"></view>
          <input
            class="search-input-small"
            placeholder="姓名/手机号"
            value="{{agentKeyword}}"
            bindinput="onAgentKeywordInput"
            bindconfirm="onSearch"
            confirm-type="search"
          />
          <view class="i-lucide-x search-clear-small" wx:if="{{agentKeyword}}" bindtap="onClearAgentKeyword"></view>
        </view>
      </view>
      
      <!-- 客户筛选框 -->
      <view class="search-item">
        <view class="search-label">客户</view>
        <view class="search-input-wrap">
          <view class="i-lucide-search search-icon-small"></view>
          <input
            class="search-input-small"
            placeholder="姓名/手机号"
            value="{{customerKeyword}}"
            bindinput="onCustomerKeywordInput"
            bindconfirm="onSearch"
            confirm-type="search"
          />
          <view class="i-lucide-x search-clear-small" wx:if="{{customerKeyword}}" bindtap="onClearCustomerKeyword"></view>
        </view>
      </view>
    </view>
    
    <!-- 经纪人：只有客户筛选框 -->
    <view wx:else>
      <view class="search-item">
        <view class="search-label">客户</view>
        <view class="search-input-wrap">
          <view class="i-lucide-search search-icon-small"></view>
          <input
            class="search-input-small"
            placeholder="姓名/手机号"
            value="{{customerKeyword}}"
            bindinput="onCustomerKeywordInput"
            bindconfirm="onSearch"
            confirm-type="search"
          />
          <view class="i-lucide-x search-clear-small" wx:if="{{customerKeyword}}" bindtap="onClearCustomerKeyword"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 结算列表 -->
  <view class="settlement-list" wx:if="{{list.length > 0}}">
    <view class="card-glass list-card settlement-card" wx:for="{{list}}" wx:key="id" bindtap="onCardTap" data-id="{{item.id}}">
      <view class="flex justify-between items-start">
        <view class="flex flex-col gap-2">
          <view class="flex items-center gap-2">
            <text class="list-title">{{item.lead.customerName}}</text>
          </view>
          <text class="list-subtitle">{{item.carText}}</text>
        </view>
        <view class="tag-{{item.statusType}}">{{item.statusText}}</view>
      </view>

      <view class="list-meta">
        <view class="chip" wx:if="{{isAdmin && item.lead.agentName}}">
          <view class="i-lucide-user text-primary"></view>
          <text>经纪人 {{item.lead.agentName}}</text>
        </view>
        <view class="chip primary">
          <text>利润 ¥{{item.profit}}</text>
        </view>
        <view class="chip success">
          <text>分成 ¥{{item.agentShare}}</text>
        </view>
        <view class="chip" wx:if="{{item.settledAt}}">
          <view class="i-lucide-calendar text-primary"></view>
          <text>结算 {{item.settledAt}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && list.length === 0}}" class="empty">
    <view class="i-lucide-inbox empty-icon"></view>
    <text wx:if="{{isGuest}}">登录后可查看结算</text>
    <text wx:elif="{{agentKeyword || customerKeyword}}">未找到匹配结果</text>
    <text wx:else>暂无结算</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">加载中...</view>
  <view class="no-more" wx:if="{{!hasMore && list.length > 0}}">没有更多了</view>

  <!-- 管理员新增按钮 -->
  <view class="fab-btn" wx:if="{{isAdmin}}" bindtap="onAddSettlement">
    <view class="fab-icon">
      <view class="fab-plus"></view>
    </view>
  </view>
  </view>
</view>
