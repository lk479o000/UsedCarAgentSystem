page {
  background: transparent;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.page {
  padding: 24rpx;
  padding-bottom: 140rpx;
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* 筛选栏 */
/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.search-icon {
  font-size: 36rpx;
  color: #94A3B8;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #0F172A;
}

/* 搜索栏清空按钮 */
.search-clear {
  font-size: 32rpx;
  color: rgba(148, 163, 184, 0.9);
  padding: 8rpx;
  border-radius: 16rpx;
}

.search-clear:active {
  background: rgba(15, 23, 42, 0.06);
}

/* filter-bar/filter-item 已沉淀到 app.wxss（本页用 flex:1 覆盖） */
.filter-item {
  flex: 1;
}

/* 筛选区域 */
.search-section {
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.search-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.search-label {
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: rgba(241, 245, 249, 0.8);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  gap: 12rpx;
}

.search-icon-small {
  font-size: 32rpx;
  color: #94A3B8;
  flex-shrink: 0;
}

.search-input-small {
  flex: 1;
  font-size: 28rpx;
  color: #0F172A;
}

.search-clear-small {
  font-size: 28rpx;
  color: rgba(148, 163, 184, 0.9);
  padding: 6rpx;
  flex-shrink: 0;
}

/* 结算卡片 */
.settlement-list {
  margin-bottom: 24rpx;
}

.settlement-card {
  margin-bottom: 24rpx;
  transition: all 0.3s ease;
}

.settlement-card:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.15);
}

/* 悬浮新增按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: calc(var(--tabbar-height) + env(safe-area-inset-bottom) + 28rpx);
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.4);
  z-index: 100;
  transition: all 0.3s ease;
}

.fab-btn:active {
  transform: scale(0.9);
  box-shadow: 0 4rpx 12rpx rgba(14, 165, 233, 0.5);
}

.fab-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fab-plus {
  width: 48rpx;
  height: 48rpx;
  position: relative;
}

.fab-plus::before,
.fab-plus::after {
  content: '';
  position: absolute;
  background-color: #fff;
}

.fab-plus::before {
  width: 100%;
  height: 6rpx;
  top: 50%;
  left: 0;
  transform: translateY(-50%);
  border-radius: 3rpx;
}

.fab-plus::after {
  width: 6rpx;
  height: 100%;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  border-radius: 3rpx;
}

/* 加载和空状态 */
.loading, .no-more {
  text-align: center;
  padding: 30rpx;
  color: #94A3B8;
  font-size: 26rpx;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #94A3B8;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
  opacity: 0.45;
}
