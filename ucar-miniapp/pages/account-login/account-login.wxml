<view class="page">
  <view class="bg-decoration">
    <view class="circle circle-1"></view>
    <view class="circle circle-2"></view>
    <view class="circle circle-3"></view>
  </view>

  <view class="login-header">
    <view class="logo-wrapper">
      <view class="logo">
        <image src="/static/icons/car-front.svg" mode="widthFix" class="car-icon" />
      </view>
    </view>
    <view class="title">账号密码登录</view>
    <view class="subtitle">请输入您的账号和密码</view>
  </view>

  <view class="login-card">
    <view class="account-panel">
      <input class="acc-input" placeholder="账号" value="{{username}}" bindinput="onUsernameInput" />
      <input class="acc-input" placeholder="密码" password value="{{password}}" bindinput="onPasswordInput" />
      <view class="captcha-row">
        <input class="acc-input captcha-input" placeholder="验证码" value="{{captcha}}" bindinput="onCaptchaInput" />
        <image class="captcha-img" src="{{captchaImage}}" mode="aspectFit" bindtap="refreshCaptcha" />
      </view>
      <button class="acc-btn" loading="{{loading}}" bindtap="onAccountLogin">登录</button>
    </view>

    <view class="go-back">
      <text class="go-back-text" bindtap="goBack">返回微信登录</text>
    </view>
  </view>
</view>
