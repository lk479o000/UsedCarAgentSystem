page {
  background: linear-gradient(160deg, #E0F2FE 0%, #DBEAFE 30%, #E0E7FF 60%, #F3E8FF 100%);
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  min-height: 100vh;
}

.page {
  min-height: 100vh;
  padding: 80rpx 40rpx 40rpx;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* 背景装饰 - 增强光晕效果 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
}

.circle {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
}

.circle-1 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(56, 189, 248, 0.5) 0%, rgba(56, 189, 248, 0.2) 40%, transparent 70%);
  top: 5%;
  left: -20%;
}

.circle-2 {
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(139, 92, 246, 0.4) 0%, rgba(139, 92, 246, 0.15) 40%, transparent 70%);
  top: 25%;
  right: -25%;
}

.circle-3 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(236, 72, 153, 0.35) 0%, rgba(236, 72, 153, 0.1) 40%, transparent 70%);
  bottom: 15%;
  left: 5%;
}

/* 登录头部 */
.login-header {
  text-align: center;
  margin-bottom: 60rpx;
  padding-top: 60rpx;
  position: relative;
  z-index: 1;
}

/* Logo 包装器 */
.logo-wrapper {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

/* Logo 玻璃方块 - 增强质感 */
.logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 
    0 8rpx 32rpx rgba(14, 165, 238, 0.15),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.6),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.4);
  position: relative;
  overflow: hidden;
}

/* Logo 内部高光反射 */
.logo::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0.1) 100%);
  border-radius: 36rpx 36rpx 0 0;
  pointer-events: none;
}

.logo .car-icon {
  width: 70rpx;
  height: 70rpx;
  display: block;
  position: relative;
  z-index: 1;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 16rpx;
  letter-spacing: -0.02em;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.subtitle {
  font-size: 28rpx;
  color: #64748B;
}

/* 登录卡片 - 增强玻璃效果 */
.login-card {
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border-radius: 40rpx;
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.06),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.8),
    inset 0 2rpx 8rpx rgba(255, 255, 255, 0.5);
  padding: 48rpx 40rpx;
  width: 100%;
  max-width: 640rpx;
  position: relative;
  z-index: 1;
  overflow: hidden;
}

/* 卡片顶部高光 */
.login-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 40%;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.5) 0%, transparent 100%);
  border-radius: 40rpx 40rpx 0 0;
  pointer-events: none;
}

.account-panel {
  position: relative;
  z-index: 1;
}

.acc-input {
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.75);
  border: 2rpx solid rgba(148, 163, 184, 0.35);
  font-size: 28rpx;
  color: #0F172A;
  box-sizing: border-box;
}

.acc-input + .acc-input {
  margin-top: 20rpx;
}

.captcha-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
}

.captcha-input {
  flex: 1;
  margin-top: 0;
}

.captcha-img {
  width: 200rpx;
  height: 88rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.85);
  border: 2rpx solid rgba(148, 163, 184, 0.35);
}

.acc-btn {
  margin-top: 32rpx;
  height: 88rpx;
  border-radius: 22rpx;
  border: none;
  background: linear-gradient(135deg, rgba(15, 23, 42, 0.85), rgba(51, 65, 85, 0.85));
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0;
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.acc-btn::after {
  border: none;
}

.go-back {
  margin-top: 32rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.go-back-text {
  font-size: 26rpx;
  color: rgba(15, 23, 42, 0.62);
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.page {
  animation: fadeIn 0.6s ease-out;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .page {
    padding: 40rpx 32rpx 32rpx;
  }
  
  .login-header {
    margin-bottom: 40rpx;
    padding-top: 40rpx;
  }
  
  .logo {
    width: 120rpx;
    height: 120rpx;
    border-radius: 32rpx;
  }
  
  .logo .car-icon {
    width: 60rpx;
    height: 60rpx;
  }
  
  .title {
    font-size: 36rpx;
  }
  
  .subtitle {
    font-size: 24rpx;
  }
  
  .login-card {
    padding: 40rpx 36rpx;
    border-radius: 36rpx;
  }
}
