<view class="aura-page with-actionbar">
  <view class="aura-bg"></view>
  <view class="aura-content">
    <view class="card-glass form-card">
      <view class="form-item">
        <text class="form-label">跟进内容 <text class="form-required">*</text></text>
        <textarea class="form-textarea" placeholder-class="form-placeholder" placeholder="请输入跟进内容" maxlength="500" value="{{followupContent}}" bindinput="onContentInput" />
      </view>

      <view class="form-item">
        <text class="form-label">跟进结果</text>
        <textarea class="form-textarea" placeholder-class="form-placeholder" placeholder="请输入跟进结果（可选）" maxlength="200" value="{{followupResult}}" bindinput="onResultInput" />
      </view>

      <view class="form-item">
        <text class="form-label">这次跟进时间 <text class="form-required">*</text></text>
        <picker mode="date" value="{{followupTime}}" bindchange="onFollowUpTimeChange">
          <view class="form-control">
            <text class="{{followupTime ? '' : 'form-placeholder'}}">{{followupTime || '请选择日期'}}</text>
            <view class="i-lucide-calendar"></view>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">下次跟进时间（可选）</text>
        <picker mode="date" value="{{nextFollowupTime}}" bindchange="onNextFollowUpTimeChange">
          <view class="form-control">
            <text class="{{nextFollowupTime ? '' : 'form-placeholder'}}">{{nextFollowupTime || '请选择日期'}}</text>
            <view class="i-lucide-calendar"></view>
          </view>
        </picker>
      </view>
    </view>
  </view>
</view>

<view class="form-actionbar-wrap">
  <view class="form-actionbar card-glass">
    <button class="btn-primary form-action-btn" loading="{{submitting}}" bindtap="onSubmit">
      {{isEdit ? '保存修改' : '确定新增'}}
    </button>
  </view>
</view>