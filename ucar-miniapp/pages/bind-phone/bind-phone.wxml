<view class="aura-page with-actionbar">
  <view class="aura-bg"></view>
  <view class="aura-content">
    <view class="card-glass p-4">
      <view class="header">
        <view class="bind-icon i-lucide-smartphone"></view>
        <view class="title">绑定手机号</view>
        <view class="subtitle">请绑定您的手机号以继续使用</view>
      </view>

      <view class="form">
        <view class="form-item">
          <text class="label">手机号</text>
          <input
            type="number"
            placeholder="请输入手机号"
            maxlength="11"
            value="{{phone}}"
            bindinput="onPhoneInput"
            class="form-input"
          />
        </view>
        <view class="form-item">
          <text class="label">昵称</text>
          <input
            type="text"
            placeholder="请输入昵称（可选）"
            value="{{nickname}}"
            bindinput="onNicknameInput"
            class="form-input"
          />
        </view>
      </view>
    </view>
  </view>
</view>

<view class="form-actionbar-wrap">
  <view class="form-actionbar card-glass">
    <button class="btn-primary form-action-btn" loading="{{loading}}" bindtap="handleBind">
      绑定手机号
    </button>
  </view>
</view>
