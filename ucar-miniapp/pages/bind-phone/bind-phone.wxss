page {
  background: #F1F5F9;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.page {
  padding: 40rpx;
  min-height: 100vh;
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
  padding-top: 40rpx;
}

.bind-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin: 0 auto 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.3);
  color: #fff;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #0F172A;
  margin-bottom: 16rpx;
  letter-spacing: -0.02em;
}

.subtitle {
  font-size: 28rpx;
  color: #94A3B8;
}

.form {
  padding: 20rpx 32rpx;
  margin-bottom: 40rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.5);
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  width: 140rpx;
  font-size: 30rpx;
  color: #0F172A;
  font-weight: 500;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: #0F172A;
  height: 60rpx;
  line-height: 60rpx;
}

.bind-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.3);
  transition: all 0.3s ease;
}

.bind-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(14, 165, 233, 0.4);
}

.bind-btn::after {
  border: none;
}
