page { background: transparent; }

.header {
  text-align: center;
  margin-bottom: 24rpx;
  padding-top: 12rpx;
}

.bind-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, rgba(34, 211, 238, 0.95) 0%, rgba(139, 92, 246, 0.9) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin: 0 auto 24rpx;
  box-shadow: 0 0 24rpx rgba(34, 211, 238, 0.28);
  color: #fff;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: rgba(15, 23, 42, 0.92);
  margin-bottom: 16rpx;
  letter-spacing: -0.02em;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(71, 85, 105, 0.85);
}

.form {
  padding: 10rpx 6rpx 0;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.85);
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  width: 140rpx;
  font-size: 30rpx;
  color: rgba(15, 23, 42, 0.55);
  font-weight: 800;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: rgba(15, 23, 42, 0.92);
  height: 60rpx;
  line-height: 60rpx;
}
