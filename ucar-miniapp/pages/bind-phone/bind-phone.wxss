.container {
  padding: 40rpx;
  background: linear-gradient(135deg, #F1F5F9 0%, #E2E8F0 100%);
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
  padding-top: 40rpx;
}

.bind-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin: 0 auto 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.3);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #0F172A;
  margin-bottom: 16rpx;
  letter-spacing: -0.02em;
}

.subtitle {
  font-size: 28rpx;
  color: #94A3B8;
}

.form {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 20rpx 32rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #E2E8F0;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E2E8F0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  width: 140rpx;
  font-size: 30rpx;
  color: #0F172A;
  font-weight: 500;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: #0F172A;
  height: 60rpx;
  line-height: 60rpx;
}

.bind-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.3);
}

.bind-btn::after {
  border: none;
}
