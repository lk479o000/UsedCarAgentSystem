page {
  background: linear-gradient(160deg, #E0F2FE 0%, #DBEAFE 30%, #E0E7FF 60%, #F3E8FF 100%);
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  min-height: 100vh;
}

.page {
  min-height: 100vh;
  padding: 80rpx 40rpx 40rpx;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* 背景装饰 - 增强光晕效果 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
}

.circle {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
}

.circle-1 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(56, 189, 248, 0.5) 0%, rgba(56, 189, 248, 0.2) 40%, transparent 70%);
  top: 5%;
  left: -20%;
}

.circle-2 {
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(139, 92, 246, 0.4) 0%, rgba(139, 92, 246, 0.15) 40%, transparent 70%);
  top: 25%;
  right: -25%;
}

.circle-3 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(236, 72, 153, 0.35) 0%, rgba(236, 72, 153, 0.1) 40%, transparent 70%);
  bottom: 15%;
  left: 5%;
}

/* 登录头部 */
.login-header {
  text-align: center;
  margin-bottom: 60rpx;
  padding-top: 60rpx;
  position: relative;
  z-index: 1;
}

/* Logo 包装器 */
.logo-wrapper {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

/* Logo 玻璃方块 - 增强质感 */
.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 
    0 8rpx 32rpx rgba(14, 165, 233, 0.15),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.6),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.4);
  position: relative;
  overflow: hidden;
}

/* Logo 内部高光反射 */
.logo::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0.1) 100%);
  border-radius: 40rpx 40rpx 0 0;
  pointer-events: none;
}

/* Logo 底部反射 */
.logo::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: 10%;
  right: 10%;
  height: 60%;
  background: radial-gradient(ellipse, rgba(14, 165, 233, 0.15) 0%, transparent 70%);
  filter: blur(20rpx);
  pointer-events: none;
}

.logo .car-icon {
  width: 80rpx;
  height: 80rpx;
  display: block;
  position: relative;
  z-index: 1;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 16rpx;
  letter-spacing: -0.02em;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.subtitle {
  font-size: 28rpx;
  color: #64748B;
}

/* 登录卡片 - 增强玻璃效果 */
.login-card {
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border-radius: 40rpx;
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.06),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.8),
    inset 0 2rpx 8rpx rgba(255, 255, 255, 0.5);
  padding: 60rpx 48rpx;
  width: 100%;
  max-width: 640rpx;
  position: relative;
  z-index: 1;
  overflow: hidden;
}

/* 卡片顶部高光 */
.login-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 40%;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.5) 0%, transparent 100%);
  border-radius: 40rpx 40rpx 0 0;
  pointer-events: none;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 48rpx;
  text-align: center;
  letter-spacing: -0.02em;
  position: relative;
  z-index: 1;
}

/* 登录按钮 - 增强立体感和闪光效果 */
.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 50%, #22D3EE 100%);
  border-radius: 48rpx;
  box-shadow: 
    0 4rpx 16rpx rgba(14, 165, 233, 0.4),
    0 8rpx 32rpx rgba(14, 165, 233, 0.2),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  position: relative;
  overflow: hidden;
}

.login-btn::after {
  border: none;
}

/* 按钮光泽扫过效果 */
.login-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
  transition: left 0.6s ease;
}

/* 按钮点击闪光 */
.login-btn:active::before {
  left: 100%;
}

.login-btn:active {
  transform: scale(0.98);
  box-shadow: 
    0 2rpx 8rpx rgba(14, 165, 233, 0.4),
    0 4rpx 16rpx rgba(14, 165, 233, 0.2);
}

/* 按钮持续微光动画 */
@keyframes btnGlow {
  0%, 100% {
    box-shadow: 
      0 4rpx 16rpx rgba(14, 165, 233, 0.4),
      0 8rpx 32rpx rgba(14, 165, 233, 0.2);
  }
  50% {
    box-shadow: 
      0 4rpx 20rpx rgba(14, 165, 233, 0.5),
      0 8rpx 40rpx rgba(14, 165, 233, 0.3);
  }
}

.login-btn {
  animation: btnGlow 3s ease-in-out infinite;
}

.login-btn .i-lucide-smartphone {
  font-size: 36rpx;
  margin-right: 16rpx;
  vertical-align: middle;
}

/* 协议 */
.agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
  flex-wrap: wrap;
  position: relative;
  z-index: 1;
  line-height: 24rpx;
}

.agreement-checkbox {
  margin-right: 12rpx;
  vertical-align: middle;
  display: flex;
  align-items: center;
  justify-content: center;
}

.agreement-checkbox .wx-checkbox-input {
  width: 20rpx !important;
  height: 20rpx !important;
  margin-right: 8rpx;
  vertical-align: middle;
  margin-top: 0 !important;
}

.agreement-text,
.agreement-link {
  vertical-align: middle;
  line-height: 24rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: #64748B;
}

.agreement-link {
  font-size: 24rpx;
  color: #0EA5E9;
  margin-left: 8rpx;
  font-weight: 500;
}

/* 开发/体验版：账号密码登录入口 */
.dev-entry {
  margin-top: 26rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.dev-link {
  font-size: 26rpx;
  color: rgba(15, 23, 42, 0.62);
}

/* 暂不登录按钮（次级操作） */
.skip-btn {
  width: 520rpx;
  height: 76rpx;
  line-height: normal;
  margin-top: 28rpx;
  border-radius: 38rpx;
  border: 2rpx solid rgba(15, 23, 42, 0.08);
  background: rgba(255, 255, 255, 0.28);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  color: rgba(15, 23, 42, 0.78);
  font-size: 26rpx;
  font-weight: 600;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  box-shadow:
    0 10rpx 30rpx rgba(15, 23, 42, 0.06),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.55);
}

.skip-btn::after {
  border: none;
}

.skip-btn-hover,
.skip-btn:active {
  transform: scale(0.99);
  background: rgba(255, 255, 255, 0.36);
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.page {
  animation: fadeIn 0.6s ease-out;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .page {
    padding: 40rpx 32rpx 32rpx;
  }
  
  .login-header {
    margin-bottom: 40rpx;
    padding-top: 40rpx;
  }
  
  .logo {
    width: 140rpx;
    height: 140rpx;
    border-radius: 36rpx;
  }
  
  .logo .car-icon {
    width: 70rpx;
    height: 70rpx;
  }
  
  .title {
    font-size: 40rpx;
  }
  
  .subtitle {
    font-size: 24rpx;
  }
  
  .login-card {
    padding: 48rpx 40rpx;
    border-radius: 36rpx;
  }
  
  .section-title {
    font-size: 32rpx;
    margin-bottom: 40rpx;
  }
  
  .login-btn {
    height: 88rpx;
    line-height: 88rpx;
    font-size: 30rpx;
    border-radius: 44rpx;
  }

  .skip-btn {
    width: 520rpx;
    height: 72rpx;
    line-height: normal;
    border-radius: 36rpx;
    font-size: 25rpx;
  }
}

/* 自定义弹窗样式 */
.modal-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-content {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 500rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-text {
  font-size: 24rpx;
  line-height: 36rpx;
  color: #666;
  text-align: center;
  margin-bottom: 40rpx;
}

.modal-link {
  color: #0EA5E9;
  text-decoration: underline;
}

.modal-buttons {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.modal-btn.cancel {
  background-color: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background-color: #0EA5E9;
  color: #fff;
}
