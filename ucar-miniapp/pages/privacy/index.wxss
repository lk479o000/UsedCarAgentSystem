.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.header {
  padding: 30rpx 0;
  text-align: center;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.content {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.section-content {
  font-size: 24rpx;
  line-height: 40rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

.list-item {
  display: flex;
  margin-bottom: 15rpx;
  align-items: flex-start;
}

.list-dot {
  font-size: 24rpx;
  color: #666;
  margin-right: 12rpx;
  margin-top: 4rpx;
  min-width: 12rpx;
}

.list-text {
  font-size: 24rpx;
  line-height: 40rpx;
  color: #666;
  flex: 1;
}

.highlight {
  font-weight: bold;
  color: #333;
}