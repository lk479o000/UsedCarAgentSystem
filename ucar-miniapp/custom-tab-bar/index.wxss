.tab-item {
  flex: 1;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  color: rgba(71, 85, 105, 0.92);
  transition: transform 0.15s ease, color 0.2s ease;
}

.tab-item:active {
  transform: scale(1.05);
}

/* ========== 方案B（当前采用）：按钮撑满整个格子 ========== */
.tab-btn {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  background: transparent;
  border: none;
  box-shadow: none;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* ========== 方案A（备用）：按钮只包裹内容，留边距 ========== */
