.tabbar-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  /* bottom gap 8–12px */
  padding: 0 24rpx env(safe-area-inset-bottom);
  z-index: 260;
  pointer-events: none;
}

.tabbar {
  /* 56px */
  height: 112rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border: 1rpx solid rgba(255, 255, 255, 0.55);
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.10);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx;
  pointer-events: auto;
  position: relative;
  overflow: hidden;
}

/* ========== 方案B（当前采用）：药丸撑满格子内边距（结算页风格） ========== */
.tab-pill {
  position: absolute;
  left: 0;
  top: 8rpx;
  bottom: 8rpx;
  border-radius: 24rpx;
  background-color: #0EA5E9;
  background-image: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  box-shadow: 0 10rpx 26rpx rgba(14, 165, 233, 0.25);
  transition: transform 280ms cubic-bezier(0.2, 0.85, 0.2, 1);
  will-change: transform;
}

/* ========== 方案A（备用）：药丸只包裹图标+文字（内嵌按钮风格） ========== */
