.tab-btn::after {
  content: none;
}

.tab-icon {
  /* 20px */
  width: 40rpx;
  height: 40rpx;
  font-size: 40rpx;
  color: currentColor;
  position: relative;
  z-index: 2;
}

.tab-text {
  /* 14px */
  font-size: 28rpx;
  font-weight: 700;
  line-height: 28rpx;
  color: currentColor;
  position: relative;
  z-index: 2;
}

.tab-item.active {
  color: #ffffff;
}

.tab-item:active .tab-btn {
  background: rgba(14, 165, 233, 0.12);
}

.tab-item:active {
  color: rgba(14, 165, 233, 0.95);
  filter: none;
}
