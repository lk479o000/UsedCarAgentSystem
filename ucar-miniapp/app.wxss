@import './unocss.wxss';

/* ========== CSS 变量系统 ========== */
:root {
  --primary: #0EA5E9;
  --primary-light: #38BDF8;
  --primary-dark: #0369A1;
  --primary-gradient: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  --neo-neon-blue: #00BFFF;
  --neo-bg-top: #061022;
  --neo-bg-mid: #0B2A4A;
  --neo-bg-bottom: #2B1B5E;
  --neo-glass-alpha: 0.75;
  --neo-blur: 10px;
  --success: #14B8A6;
  --warning: #F59E0B;
  --danger: #EF4444;
  --info: #3B82F6;
  --background: #F1F5F9;
  --surface: rgba(255, 255, 255, 0.85);
  --text-primary: #0F172A;
  --text-secondary: #475569;
  --border: rgba(255, 255, 255, 0.3);
  --highlight: #22D3EE;
  --accent: #06B6D4;
  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4px 6px rgba(0, 0, 0, 0.1);
  --shadow-lg: 0 10px 15px rgba(0, 0, 0, 0.15);
  --shadow-glow: 0 0 20px rgba(14, 165, 233, 0.3);
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --radius-xl: 24px;
  --radius-full: 9999px;
  --space-1: 8px;
  --space-2: 16px;
  --space-3: 24px;
  --space-4: 32px;
  --space-5: 48px;
  --font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

page {
  font-family: var(--font-family);
  font-size: 16px;
  line-height: 24px;
  color: var(--text-primary);
  background-color: var(--background);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ========== Aura 浅色渐变（参考登录页） ========== */
.aura-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: linear-gradient(160deg, #E0F2FE 0%, #DBEAFE 30%, #E0E7FF 60%, #F3E8FF 100%);
}

.aura-bg {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  background:
    radial-gradient(520rpx 520rpx at 12% 14%, rgba(56, 189, 248, 0.38), rgba(56, 189, 248, 0.12) 38%, rgba(56, 189, 248, 0) 68%),
    radial-gradient(640rpx 640rpx at 88% 18%, rgba(139, 92, 246, 0.30), rgba(139, 92, 246, 0.10) 42%, rgba(139, 92, 246, 0) 70%),
    radial-gradient(520rpx 520rpx at 22% 82%, rgba(236, 72, 153, 0.22), rgba(236, 72, 153, 0.08) 40%, rgba(236, 72, 153, 0) 72%);
  filter: blur(0);
}

.aura-content {
  position: relative;
  padding: 24rpx 22rpx;
  animation: fadeIn 0.4s ease-out;
}

/* ========== Neo 主题骨架（全站统一） ========== */
.neo-page {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(180deg, var(--neo-bg-top) 0%, var(--neo-bg-mid) 52%, var(--neo-bg-bottom) 100%);
  overflow: hidden;
}

.neo-bg {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(900rpx 620rpx at 20% 12%, rgba(34, 211, 238, 0.42), rgba(34, 211, 238, 0) 62%),
    radial-gradient(860rpx 620rpx at 82% 10%, rgba(139, 92, 246, 0.42), rgba(139, 92, 246, 0) 64%),
    radial-gradient(1200rpx 720rpx at 40% 72%, rgba(0, 191, 255, 0.12), rgba(0, 191, 255, 0) 66%),
    linear-gradient(180deg, var(--neo-bg-top) 0%, var(--neo-bg-mid) 52%, var(--neo-bg-bottom) 100%);
}

.neo-page::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 300rpx;
  background: rgba(11, 18, 32, calc(var(--neo-glass-alpha) * 0.35));
  backdrop-filter: blur(var(--neo-blur));
  -webkit-backdrop-filter: blur(var(--neo-blur));
  box-shadow: 0 -18rpx 60rpx rgba(0, 0, 0, 0.22) inset;
  pointer-events: none;
}

.neo-content {
  position: relative;
  padding: 24rpx 22rpx;
  animation: fadeIn 0.4s ease-out;
}

.neo-title {
  font-size: 28rpx;
  font-weight: 900;
  color: rgba(226, 232, 240, 0.75);
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.neo-text {
  color: rgba(226, 232, 240, 0.86);
}

.neo-subtext {
  color: rgba(226, 232, 240, 0.65);
}

.neo-card.card-glass {
  background: rgba(255, 255, 255, 0.10);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  box-shadow: 0 18rpx 60rpx rgba(0, 0, 0, 0.28);
}

.neo-input {
  background: rgba(255, 255, 255, 0.10);
  border: 1rpx solid rgba(34, 211, 238, 0.20);
  color: rgba(255, 255, 255, 0.92);
  border-radius: 26rpx;
}

.neo-kbd {
  color: rgba(255, 255, 255, 0.92);
}

.neo-divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.12);
}

.neo-page .list-title { color: rgba(255, 255, 255, 0.92); }
.neo-page .list-subtitle { color: rgba(226, 232, 240, 0.72); }

.neo-page .chip {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  color: rgba(226, 232, 240, 0.78);
}

.neo-page .chip.primary {
  background: rgba(34, 211, 238, 0.12);
  border-color: rgba(34, 211, 238, 0.18);
  color: rgba(34, 211, 238, 0.95);
}

.neo-page .chip.success {
  background: rgba(16, 185, 129, 0.12);
  border-color: rgba(16, 185, 129, 0.18);
  color: rgba(16, 185, 129, 0.92);
}

.neo-page .note-block {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.neo-page .note-title { color: rgba(226, 232, 240, 0.62); }
.neo-page .note-text { color: rgba(226, 232, 240, 0.82); }

.neo-page .search-icon { color: rgba(226, 232, 240, 0.55); }
.neo-page .search-input { color: rgba(255, 255, 255, 0.92); }
.neo-page .search-clear { color: rgba(226, 232, 240, 0.65); }

.neo-page .empty,
.neo-page .loading,
.neo-page .no-more { color: rgba(226, 232, 240, 0.65); }

/* 表单控件（在 Neo 深色背景下的统一覆盖） */
.neo-page .form-label {
  color: rgba(226, 232, 240, 0.75);
}

.neo-page .form-control,
.neo-page .dialog-input {
  background: rgba(255, 255, 255, 0.10);
  border-color: rgba(34, 211, 238, 0.20);
  color: rgba(255, 255, 255, 0.92);
}

.neo-page .form-input {
  color: rgba(255, 255, 255, 0.92);
}

.neo-page .form-textarea {
  background: rgba(255, 255, 255, 0.10);
  border-color: rgba(34, 211, 238, 0.20);
  color: rgba(255, 255, 255, 0.92);
}

.neo-page .form-placeholder {
  color: rgba(226, 232, 240, 0.45);
}

.neo-page .form-control .i-lucide-calendar,
.neo-page .form-control .i-lucide-chevron-down,
.neo-page .form-control .i-lucide-chevron-right {
  color: rgba(226, 232, 240, 0.55);
}

/* 底部操作栏（Neo） */
.neo-page .detail-actionbar.card-glass,
.neo-page .form-actionbar.card-glass {
  background: rgba(255, 255, 255, 0.10);
  border-color: rgba(255, 255, 255, 0.18);
  box-shadow: 0 18rpx 60rpx rgba(0, 0, 0, 0.28);
}

/* ========== TabBar / 安全区（全局沉淀） ========== */
:root {
  /* 自定义 TabBar 外部占用高度（不要把内部 padding 也算进去） */
  --tabbar-height: 112rpx;
}

.with-tabbar {
  /* 兜底 160rpx，避免部分机型/基础库变量失效导致遮挡 */
  padding-bottom: calc(var(--tabbar-height, 160rpx) + env(safe-area-inset-bottom) + 16rpx) !important;
}

/* 某些基础库对 :root 变量不稳定，page 再定义一份 */
page {
  --tabbar-height: 112rpx;
}

/* ========== 底部固定操作栏（表单/详情通用） ========== */
.with-actionbar {
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom) + 24rpx) !important;
}

.form-actionbar-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom));
  z-index: 180;
}

.form-actionbar {
  height: 112rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.10);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
}

.form-action-btn {
  width: 100%;
  height: 92rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: normal;
}

.form-action-btn::after {
  border: none;
}

/* ========== 图标盒子兜底（修复宽高为0） ========== */
[class^="i-lucide-"],
[class*=" i-lucide-"] {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 1em;
  height: 1em;
  line-height: 1;
  flex-shrink: 0;
}

/* ========== 玻璃拟态卡片 ========== */
.card-glass {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
}

.card-glass:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.15);
}

/* ========== 按钮样式 ========== */
.btn-primary {
  background: linear-gradient(135deg, #0EA5E9, #38BDF8);
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  box-shadow: 0 4rpx 8rpx rgba(14, 165, 233, 0.3);
  transition: all 0.3s ease;
  border: none;
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 4rpx rgba(14, 165, 233, 0.4);
}

.btn-ghost {
  background: rgba(255, 255, 255, 0.38);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  color: rgba(15, 23, 42, 0.78);
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  border: 2rpx solid rgba(15, 23, 42, 0.08);
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.06), inset 0 0 0 1rpx rgba(255, 255, 255, 0.55);
  transition: all 0.3s ease;
}

.btn-ghost:active {
  transform: scale(0.98);
  background: rgba(255, 255, 255, 0.46);
}

.btn-ghost::after {
  border: none;
}

.btn-success {
  background: linear-gradient(135deg, #14B8A6, #22D3EE);
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  box-shadow: 0 4rpx 8rpx rgba(20, 184, 166, 0.3);
  transition: all 0.3s ease;
  border: none;
}

.btn-success:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 4rpx rgba(20, 184, 166, 0.4);
}

.btn-danger {
  background: linear-gradient(135deg, #EF4444, #F87171);
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  box-shadow: 0 4rpx 8rpx rgba(239, 68, 68, 0.3);
  transition: all 0.3s ease;
  border: none;
}

.btn-danger:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 4rpx rgba(239, 68, 68, 0.4);
}

/* ========== 标签样式 ========== */
.tag-primary {
  background: rgba(14, 165, 233, 0.1);
  color: #0369A1;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.tag-success {
  background: rgba(20, 184, 166, 0.1);
  color: #14B8A6;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.tag-warning {
  background: rgba(245, 158, 11, 0.1);
  color: #F59E0B;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.tag-danger {
  background: rgba(239, 68, 68, 0.1);
  color: #EF4444;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.tag-info {
  background: rgba(59, 130, 246, 0.12);
  color: #3B82F6;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

/* ========== 文本颜色工具类（全局沉淀） ========== */
.text-primary { color: var(--primary); }
.text-success { color: var(--success); }
.text-warning { color: var(--warning); }
.text-danger { color: var(--danger); }

/* ========== 排版系统 ========== */
h1, .h1 {
  font-size: 36px;
  font-weight: 700;
  line-height: 44px;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  margin-bottom: 24px;
}

h2, .h2 {
  font-size: 28px;
  font-weight: 600;
  line-height: 36px;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  margin-bottom: 20px;
}

h3, .h3 {
  font-size: 20px;
  font-weight: 600;
  line-height: 28px;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  margin-bottom: 16px;
}

p, .body {
  font-size: 16px;
  font-weight: 400;
  line-height: 24px;
  color: var(--text-secondary);
  letter-spacing: 0;
}

.small {
  font-size: 13px;
  font-weight: 400;
  line-height: 20px;
  color: var(--text-secondary);
}

.text-uppercase {
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

/* ========== 动画效果 ========== */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateX(-20px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes pulse {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(14, 165, 233, 0.4);
  }
  50% {
    box-shadow: 0 0 0 10px rgba(14, 165, 233, 0);
  }
}

@keyframes glow {
  0%, 100% {
    box-shadow: 0 0 5px rgba(14, 165, 233, 0.3);
  }
  50% {
    box-shadow: 0 0 20px rgba(14, 165, 233, 0.6), 0 0 40px rgba(34, 211, 238, 0.3);
  }
}

.animate-fade-in {
  animation: fadeIn 0.4s ease-out;
}

.animate-slide-in {
  animation: slideIn 0.4s ease-out;
}

.animate-pulse {
  animation: pulse 2s infinite;
}

.animate-glow {
  animation: glow 2s ease-in-out infinite;
}

/* ========== 滚动条样式 ========== */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: #94a3b8;
}

/* ========== 响应式设计 ========== */
@media (max-width: 768px) {
  h1, .h1 {
    font-size: 28px;
    line-height: 36px;
  }
  h2, .h2 {
    font-size: 22px;
    line-height: 30px;
  }
  h3, .h3 {
    font-size: 18px;
    line-height: 26px;
  }
}

/* ========== 表单控件（全局沉淀） ========== */
.form-card {
  padding: 30rpx 26rpx;
  border-radius: 28rpx;
}

.form-item {
  margin-bottom: 22rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(15, 23, 42, 0.78);
  margin-bottom: 12rpx;
}

.form-required {
  color: var(--danger);
  margin-left: 6rpx;
}

.form-control {
  height: 88rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.75);
  border: 2rpx solid rgba(148, 163, 184, 0.35);
  font-size: 28rpx;
  color: #0F172A;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.form-control:active {
  border-color: rgba(14, 165, 233, 0.35);
}

.form-input {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  color: #0F172A;
}

.form-placeholder {
  color: rgba(148, 163, 184, 1);
}

.form-textarea {
  min-height: 180rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.75);
  border: 2rpx solid rgba(148, 163, 184, 0.35);
  font-size: 28rpx;
  color: #0F172A;
  box-sizing: border-box;
}

.form-submit {
  width: 100%;
  height: 96rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: normal;
}

.form-submit::after {
  border: none;
}

/* ========== 弹层（全局沉淀） ========== */
.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 220;
}

.sheet-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom));
  z-index: 260;
}

.sheet {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.88);
  overflow: hidden;
  box-shadow: 0 18rpx 50rpx rgba(15, 23, 42, 0.18);
}

.sheet-title {
  padding: 26rpx 24rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #0F172A;
  text-align: center;
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.6);
}

.sheet-list {
  padding: 10rpx 14rpx;
}

.sheet-item {
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0F172A;
  font-size: 28rpx;
  font-weight: 600;
}

.sheet-item:active {
  background: rgba(14, 165, 233, 0.08);
}

.sheet-item-text {
  font-size: 28rpx;
  font-weight: 600;
  color: inherit;
}

.sheet-cancel {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: rgba(15, 23, 42, 0.6);
  border-top: 1rpx solid rgba(226, 232, 240, 0.6);
}

.dialog-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 240;
}

.dialog {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 82%;
  max-width: 640rpx;
  padding: 30rpx 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 20rpx 60rpx rgba(15, 23, 42, 0.22);
  z-index: 280;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #0F172A;
  text-align: center;
  margin-bottom: 20rpx;
}

.dialog-input {
  height: 86rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.75);
  border: 2rpx solid rgba(148, 163, 184, 0.35);
  font-size: 28rpx;
  color: #0F172A;
  box-sizing: border-box;
}

.dialog-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.dialog-btn {
  flex: 1;
  height: 86rpx;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: normal;
  border: none;
}

.dialog-btn::after {
  border: none;
}

.dialog-btn.ghost {
  background: rgba(15, 23, 42, 0.06);
  color: rgba(15, 23, 42, 0.72);
}

.dialog-btn.primary {
  background: var(--primary-gradient);
  color: #fff;
  box-shadow: 0 10rpx 26rpx rgba(14, 165, 233, 0.25);
}

.dialog-btn:active {
  transform: scale(0.98);
}

/* ========== 列表/信息展示（全局沉淀） ========== */
.list-card {
  padding: 28rpx 26rpx;
  border-radius: 28rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: 800;
  line-height: 40rpx;
  color: #0F172A;
}

.list-subtitle {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: rgba(71, 85, 105, 0.9);
}

.list-meta {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.chip {
  height: 52rpx;
  padding: 0 16rpx;
  border-radius: 9999rpx;
  background: rgba(15, 23, 42, 0.06);
  color: rgba(15, 23, 42, 0.72);
  font-size: 22rpx;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.chip.primary {
  background: rgba(14, 165, 233, 0.12);
  color: #0369A1;
}

.chip.success {
  background: rgba(20, 184, 166, 0.12);
  color: #0F766E;
}

.chip.warning {
  background: rgba(245, 158, 11, 0.12);
  color: #B45309;
}

.chip.danger {
  background: rgba(239, 68, 68, 0.12);
  color: #B91C1C;
}

.kv-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.75);
}

.kv-row:last-child {
  border-bottom: none;
}

.kv-label {
  width: 170rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(15, 23, 42, 0.42);
}

.kv-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: rgba(15, 23, 42, 0.92);
}

.note-block {
  margin-top: 18rpx;
  padding: 18rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(241, 245, 249, 0.8);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.note-title {
  font-size: 22rpx;
  font-weight: 800;
  color: rgba(15, 23, 42, 0.55);
  margin-bottom: 10rpx;
}

.note-text {
  font-size: 26rpx;
  line-height: 38rpx;
  color: rgba(15, 23, 42, 0.75);
}

/* ========== 底部操作栏（全局沉淀） ========== */
.detail-actionbar-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom));
  z-index: 120;
}

.detail-actionbar {
  height: 112rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.10);
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 10rpx;
}

.detail-action {
  flex: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: rgba(15, 23, 42, 0.65);
}

.detail-action.primary { color: var(--primary); }
.detail-action.success { color: var(--success); }
.detail-action.warning { color: var(--warning); }
.detail-action.danger { color: var(--danger); }

.detail-action-icon {
  font-size: 44rpx;
  color: currentColor;
}

.detail-action-text {
  font-size: 22rpx;
  font-weight: 700;
  line-height: 22rpx;
}

/* ========== 筛选栏（全局沉淀） ========== */
.filter-bar {
  display: flex;
  padding: 10rpx;
  margin-bottom: 24rpx;
  white-space: nowrap;
  gap: 10rpx;
}

.filter-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  padding: 0 18rpx;
  font-size: 26rpx;
  color: rgba(71, 85, 105, 0.92);
  border-radius: 24rpx;
  font-weight: 700;
  transition: all 0.3s ease;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.52);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.filter-item.active {
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(14, 165, 233, 0.3);
}
