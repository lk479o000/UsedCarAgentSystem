@import './unocss.wxss';

/* ========== CSS 变量系统 ========== */
:root {
  --primary: #0EA5E9;
  --primary-light: #38BDF8;
  --primary-dark: #0369A1;
  --primary-gradient: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  --success: #14B8A6;
  --warning: #F59E0B;
  --danger: #EF4444;
  --info: #3B82F6;
  --background: #F1F5F9;
  --surface: rgba(255, 255, 255, 0.85);
  --text-primary: #0F172A;
  --text-secondary: #475569;
  --border: rgba(255, 255, 255, 0.3);
  --highlight: #22D3EE;
  --accent: #06B6D4;
  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4px 6px rgba(0, 0, 0, 0.1);
  --shadow-lg: 0 10px 15px rgba(0, 0, 0, 0.15);
  --shadow-glow: 0 0 20px rgba(14, 165, 233, 0.3);
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --radius-xl: 24px;
  --radius-full: 9999px;
  --space-1: 8px;
  --space-2: 16px;
  --space-3: 24px;
  --space-4: 32px;
  --space-5: 48px;
  --font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

page {
  font-family: var(--font-family);
  font-size: 16px;
  line-height: 24px;
  color: var(--text-primary);
  background-color: var(--background);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ========== 玻璃拟态卡片 ========== */
.card-glass {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
}

.card-glass:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.15);
}

/* ========== 按钮样式 ========== */
.btn-primary {
  background: linear-gradient(135deg, #0EA5E9, #38BDF8);
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  box-shadow: 0 4rpx 8rpx rgba(14, 165, 233, 0.3);
  transition: all 0.3s ease;
  border: none;
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 4rpx rgba(14, 165, 233, 0.4);
}

.btn-success {
  background: linear-gradient(135deg, #14B8A6, #22D3EE);
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  box-shadow: 0 4rpx 8rpx rgba(20, 184, 166, 0.3);
  transition: all 0.3s ease;
  border: none;
}

.btn-success:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 4rpx rgba(20, 184, 166, 0.4);
}

.btn-danger {
  background: linear-gradient(135deg, #EF4444, #F87171);
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  box-shadow: 0 4rpx 8rpx rgba(239, 68, 68, 0.3);
  transition: all 0.3s ease;
  border: none;
}

.btn-danger:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 4rpx rgba(239, 68, 68, 0.4);
}

/* ========== 标签样式 ========== */
.tag-primary {
  background: rgba(14, 165, 233, 0.1);
  color: #0369A1;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.tag-success {
  background: rgba(20, 184, 166, 0.1);
  color: #14B8A6;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.tag-warning {
  background: rgba(245, 158, 11, 0.1);
  color: #F59E0B;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.tag-danger {
  background: rgba(239, 68, 68, 0.1);
  color: #EF4444;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

/* ========== 排版系统 ========== */
h1, .h1 {
  font-size: 36px;
  font-weight: 700;
  line-height: 44px;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  margin-bottom: 24px;
}

h2, .h2 {
  font-size: 28px;
  font-weight: 600;
  line-height: 36px;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  margin-bottom: 20px;
}

h3, .h3 {
  font-size: 20px;
  font-weight: 600;
  line-height: 28px;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  margin-bottom: 16px;
}

p, .body {
  font-size: 16px;
  font-weight: 400;
  line-height: 24px;
  color: var(--text-secondary);
  letter-spacing: 0;
}

.small {
  font-size: 13px;
  font-weight: 400;
  line-height: 20px;
  color: var(--text-secondary);
}

.text-uppercase {
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

/* ========== 动画效果 ========== */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateX(-20px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes pulse {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(14, 165, 233, 0.4);
  }
  50% {
    box-shadow: 0 0 0 10px rgba(14, 165, 233, 0);
  }
}

@keyframes glow {
  0%, 100% {
    box-shadow: 0 0 5px rgba(14, 165, 233, 0.3);
  }
  50% {
    box-shadow: 0 0 20px rgba(14, 165, 233, 0.6), 0 0 40px rgba(34, 211, 238, 0.3);
  }
}

.animate-fade-in {
  animation: fadeIn 0.4s ease-out;
}

.animate-slide-in {
  animation: slideIn 0.4s ease-out;
}

.animate-pulse {
  animation: pulse 2s infinite;
}

.animate-glow {
  animation: glow 2s ease-in-out infinite;
}

/* ========== 滚动条样式 ========== */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: #94a3b8;
}

/* ========== 响应式设计 ========== */
@media (max-width: 768px) {
  h1, .h1 {
    font-size: 28px;
    line-height: 36px;
  }
  h2, .h2 {
    font-size: 22px;
    line-height: 30px;
  }
  h3, .h3 {
    font-size: 18px;
    line-height: 26px;
  }
}
